    "quest_data": {
      "chapter_id": "C2",
      "chapter_title": "The Puppeteer's Shadow",
      "quest_type": "main",
      "required": true,
      "scale": "large",
      "quests": [
        {
          "quest_id": "Q2_1",
          "quest_title": "Whispers in the Store",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "safehouse",
                "to": "village"
              }
            },
            {
              "step": 2,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "store"
              }
            },
            {
              "step": 3,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "anne",
                "place": "store",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Anne, the rumors are getting worse. People say someone is pulling the strings behind the chaos."
                  },
                  {
                    "speaker": "anne",
                    "line": "Rumors are cheap, traveler. But the patterns I've seen in my ledgers and the movements outside aren't. Viktor isn't just holding the outpost; he's directing traffic."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Viktor? I thought he was just a warlord trying to survive."
                  },
                  {
                    "speaker": "anne",
                    "line": "Survival is his excuse. Control is his goal. He's been coordinating with the Doctor at the Outpost. They aren't just hiding; they're building something."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "What kind of something?"
                  },
                  {
                    "speaker": "anne",
                    "line": "I don't know the details. But I saw a key pass through here recently. It wasn't for the village. It was for the Outpost. If you want to find the source, you need to get past the first line of defense."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Where is this key?"
                  },
                  {
                    "speaker": "anne",
                    "line": "I can't say for sure. But if I were you, I'd check the old cave system near the village. That's where the stragglers go when they think no one is watching."
                  }
                ]
              }
            }
          ]
        },
        {
          "quest_id": "Q2_2",
          "quest_title": "The Key to the Outpost",
          "steps": [
            {
              "step": 4,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "store",
                "to": "village"
              }
            },
            {
              "step": 5,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "cave"
              }
            },
            {
              "step": 6,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "outpost_key_1",
                "place": "cave"
              }
            },
            {
              "step": 7,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "cave",
                "to": "village"
              }
            },
            {
              "step": 8,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "outpost1"
              }
            },
            {
              "step": 9,
              "action": "UNLOCK",
              "actor": "player",
              "parameters": {
                "key_item": "outpost_key_1",
                "target_place": "outpost1"
              }
            },
            {
              "step": 10,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "outpost2"
              }
            },
            {
              "step": 11,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "viktor",
                "place": "outpost2",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Viktor. I know you're pulling the strings. Anne saw the coordination."
                  },
                  {
                    "speaker": "viktor",
                    "line": "Anne sees what she wants to see. I provide order where there is only chaos. The Doctor and I are securing the island's future."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "By locking people out and hoarding resources? That's not order, that's tyranny."
                  },
                  {
                    "speaker": "viktor",
                    "line": "Tyranny is a word used by the weak who cannot handle the hard choices. I am making the island safe. You are just another variable in my equation."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I'm coming for the truth, and I'm coming for the Outpost."
                  },
                  {
                    "speaker": "viktor",
                    "line": "Then you will find only what I allow you to find. The Doctor is waiting in the lower levels. If you survive the journey, perhaps you'll understand the necessity of my methods."
                  }
                ]
              }
            }
          ]
        },
        {
          "quest_id": "Q2_3",
          "quest_title": "The Doctor's Gambit",
          "steps": [
            {
              "step": 12,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost3"
              }
            },
            {
              "step": 13,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "the_doctor",
                "place": "outpost3",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Doctor. Viktor thinks he's the mastermind, but you're the one behind the experiments."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Viktor is a brute with a clipboard. I am the mind. This outbreak is not a tragedy; it is an unprecedented opportunity for data collection."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "You're using people as test subjects. That's monstrous."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Monstrous is letting humanity rot in the dark. I am trying to synthesize a cure, but the variables are... unpredictable. I need more samples."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "You won't get any more from me. I'm here to stop you."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Stop me? You cannot stop progress. I have already sent my findings to a secure server. Even if you destroy this lab, the data survives. But if you wish to proceed, you will find the cure sample I need is missing."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Missing? Where is it?"
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "It was stolen. Or perhaps misplaced. Check the Laboratory in the village. Sarah is there. She may have it, or she may have destroyed it. The outcome is irrelevant to the final result."
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  },
  {
