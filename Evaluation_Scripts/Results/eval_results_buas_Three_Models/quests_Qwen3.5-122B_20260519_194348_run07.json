              }
            },
            {
              "step": 18,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital2",
                "to": "hospital1"
              }
            },
            {
              "step": 19,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital1",
                "to": "village"
              }
            },
            {
              "step": 20,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "laboratory"
              }
            },
            {
              "step": 21,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, I brought the sample. You need to synthesize the cure."
                  },
                  {
                    "speaker": "sarah",
                    "line": "You're here. Good. I've been analyzing the pathogen, but I can't proceed while I'm... compromised. I feel the fever rising. If I don't get help, I'll be useless to everyone."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Let me help you. First, I need to get you stable."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Do it. But hurry. Once I'm clear, we can make the antidote for the village."
                  }
                ]
              }
            },
            {
              "step": 22,
              "action": "SYNTHESIZE_CURE",
              "actor": "player",
              "parameters": {
                "place": "laboratory"
              }
            },
            {
              "step": 23,
