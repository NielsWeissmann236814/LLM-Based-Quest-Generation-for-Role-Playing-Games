      "chapter_id": "C1",
      "chapter_title": "The First Spark",
      "quest_type": "main",
      "required": true,
      "scale": "medium",
      "quests": [
        {
          "quest_id": "Q1_1",
          "quest_title": "The Village Briefing",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "safehouse",
                "to": "village"
              }
            },
            {
              "step": 2,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "anne",
                "place": "store",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Anne, the village is dying. People are getting sick, and the power is out. What's the plan?"
                  },
                  {
                    "speaker": "anne",
                    "line": "The plan? Survival, mostly. But I've heard whispers from Sarah. She thinks she found a sample in the hospital that could help, but she's locked out of her lab, and the power's dead."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah? I saw her at the lab earlier. She looked... off. Is she infected?"
                  },
                  {
                    "speaker": "anne",
                    "line": "I haven't seen her in days, but the Doctor mentioned she's struggling. If you can get her a cure, she might be able to synthesize a batch for the rest of us. But first, you need to get into that lab."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "The lab is locked. Do you know where the key is?"
                  },
                  {
                    "speaker": "anne",
                    "line": "Keys have a way of ending up where they shouldn't. I heard one was taken to the graveyard by a scavenger. If you're going to try to save us, start there. And take some wood with you; the village needs fortifying before nightfall."
                  }
                ]
              }
            },
            {
              "step": 3,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "wood_1",
                "place": "village"
              }
            }
          ]
        },
