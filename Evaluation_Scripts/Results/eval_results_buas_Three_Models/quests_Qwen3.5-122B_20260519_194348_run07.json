              }
            },
            {
              "step": 11,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "powerstation"
              }
            },
            {
              "step": 12,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "george",
                "place": "powerstation",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "George, I have a fuse. Can we get the lab back online?"
                  },
                  {
                    "speaker": "george",
                    "line": "Finally. I've been staring at this dead grid for hours. If you have the fuse, install it now. The lab needs power if Sarah is to do any work."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Done. Power is on."
                  }
                ]
              }
            },
            {
              "step": 13,
              "action": "TURN_POWER_ON",
              "actor": "player",
              "parameters": {
                "fuse_item": "fuse_1",
                "place": "powerstation",
                "target_place": "laboratory"
              }
            }
          ]
        },
        {
          "quest_id": "Q1_4",
          "quest_title": "A Cure for Sarah",
          "steps": [
            {
              "step": 14,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
