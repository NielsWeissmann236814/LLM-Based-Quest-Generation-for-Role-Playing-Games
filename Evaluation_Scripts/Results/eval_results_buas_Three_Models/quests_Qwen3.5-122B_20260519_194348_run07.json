              }
            },
            {
              "step": 22,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "The boat is fixed. I have the cure synthesized. We're ready to go."
                  },
                  {
                    "speaker": "mary",
                    "line": "Then stop wasting time. The engine is warm. Get on board."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah is coming too. She's the only one who knows the data."
                  },
                  {
                    "speaker": "mary",
                    "line": "Then she better move fast. The island isn't going to wait for her to pack a bag."
                  }
                ]
              }
            },
            {
              "step": 23,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, the boat is ready. We have the antidote. It's time to leave."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Confirmed. The synthesis is complete. I am ready to depart. This chapter is closed."
                  }
                ]
              }
