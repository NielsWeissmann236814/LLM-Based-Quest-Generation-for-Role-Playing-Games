              "step": 5,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "laboratory"
              }
            },
            {
              "step": 6,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, the boat is the only way off this island. But Mary can't fix it alone. We need to leave now."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Leaving is the logical choice. My work here is finished. The data is preserved, and the cure formula is stable."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Then come with us. But we need a cure sample to synthesize the antidote for anyone we might leave behind or to save ourselves if things go wrong."
                  },
                  {
                    "speaker": "sarah",
                    "line": "I have the sample isolated. I was waiting for the power to stabilize completely, but it is on now. I will prepare it for you before we board."
                  }
                ]
              }
            }
          ]
        },
        {
          "quest_id": "C3_Q2",
          "quest_title": "Powering the Exit",
          "steps": [
            {
              "step": 7,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 8,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "powerstation"
              }
            },
            {
              "step": 9,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "george",
                "place": "powerstation",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "George, we're leaving. The grid is holding, but we need to make sure the dock lights stay on for the night watch."
                  },
                  {
                    "speaker": "george",
                    "line": "The grid is stable. I've run the diagnostics. The power station is secure."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Good. We're taking Sarah. She has the cure sample. We need to get the boat ready immediately."
                  },
                  {
                    "speaker": "george",
                    "line": "Understood. Go. I will maintain the system until the last possible second. Don't look back."
                  }
                ]
              }
            }
          ]
        },
        {
          "quest_id": "C3_Q3",
          "quest_title": "The Final Repair",
          "steps": [
            {
              "step": 10,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "powerstation",
                "to": "village"
              }
            },
            {
              "step": 11,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "dock"
              }
            },
            {
              "step": 12,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Mary, I have the toolkit. We can fix the boat now."
                  },
                  {
                    "speaker": "mary",
                    "line": "About time. I've been staring at this hull for three days. Hand it over."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "It's not just the toolkit. I need wood too. I have some in my inventory, but we might need more from the village."
                  },
                  {
                    "speaker": "mary",
                    "line": "We have what we need. Just get to work. The tide isn't waiting for anyone."
                  }
                ]
              }
            },
            {
              "step": 13,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "wood_3",
                "place": "village"
              }
            },
            {
              "step": 14,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "dock"
              }
            },
            {
              "step": 15,
              "action": "REPAIR",
              "actor": "player",
              "parameters": {
                "toolkit_item": "toolkit_1",
                "wood_item": "wood_3",
                "target": "boat",
                "place": "dock"
              }
            }
          ]
        },
        {
          "quest_id": "C3_Q4",
          "quest_title": "Synthesis and Departure",
          "steps": [
