              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "viktor",
                "place": "outpost2",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "I've seen what you're doing out here, Viktor. The control, the fear."
                  },
                  {
                    "speaker": "viktor",
                    "line": "Control is order. Without it, we are just meat waiting to be eaten. You're welcome for the structure I provide."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "It's not structure. It's tyranny. And I'm not interested in your order."
                  },
                  {
                    "speaker": "viktor",
                    "line": "Then you are a variable I will have to eliminate. Or perhaps you'll find that resistance is a luxury the island can no longer afford."
                  }
                ]
              }
            }
          ]
        },
        {
          "quest_id": "Q2_3",
          "quest_title": "The Architect's Lab",
          "steps": [
