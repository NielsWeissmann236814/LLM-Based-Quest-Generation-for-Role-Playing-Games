              "step": 6,
              "action": "UNLOCK",
              "actor": "player",
              "parameters": {
                "key_item": "lab_key_1",
                "target_place": "laboratory"
              }
            },
            {
              "step": 7,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, I'm here to find out what's going on with the Doctor. What do you know?"
                  },
                  {
                    "speaker": "sarah",
                    "line": "The Doctor isn't trying to cure the outbreak. He's enhancing it. His research logs are encrypted, but I've been working on a bypass."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Can you show me?"
                  },
                  {
                    "speaker": "sarah",
                    "line": "I can. But you need to be careful. If he finds out, he'll stop at nothing to protect his work."
                  }
                ]
              }
            },
            {
              "step": 8,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "cure_sample_1",
                "place": "laboratory"
              }
            },
            {
              "step": 9,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 10,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "outpost1"
              }
            },
            {
              "step": 11,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "outpost2"
              }
            },
            {
              "step": 12,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "viktor",
                "place": "outpost2",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Viktor, I know you're working with the Doctor. What's the endgame?"
                  },
                  {
                    "speaker": "viktor",
                    "line": "Order. The Doctor provides the tools for control. I provide the force to maintain it. It's a symbiosis."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "It's a tyranny. I'm going to expose his research."
                  },
                  {
                    "speaker": "viktor",
                    "line": "You can try. But my men are everywhere. Be careful what you uncover."
                  }
                ]
              }
            },
            {
              "step": 13,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost3"
              }
            },
            {
              "step": 14,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "the_doctor",
                "place": "outpost3",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "I have your sample, Doctor. And I know what you're doing."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "You have a crude understanding of evolutionary necessity. This sample is not a cure. It is a catalyst."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "It's a weapon. And I'm taking it away from you."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "You cannot stop progress. But you can certainly delay it. Do what you must. The data is already backed up."
                  }
                ]
              }
            }
          ]
        },
        {
          "quest_id": "Q2_2",
