            {
              "step": 18,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "store"
              }
            },
            {
              "step": 19,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "anne",
                "place": "store",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "The Doctor is using the outbreak to create a controlled population. I need to tell everyone."
                  },
                  {
                    "speaker": "anne",
                    "line": "People are scared. They need proof, not just words. But I can help you spread the word if you have something tangible."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I have the sample. And I know Viktor is protecting him."
                  },
                  {
                    "speaker": "anne",
                    "line": "Then we need to make sure the right people hear it. Go to Marcus. He respects strength and truth."
                  }
                ]
              }
            },
            {
              "step": 20,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "store",
                "to": "village"
              }
            },
            {
              "step": 21,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "hospital1"
              }
            },
            {
              "step": 22,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital1",
                "to": "hospital2"
              }
            },
            {
              "step": 23,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "marcus",
                "place": "hospital2",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Marcus, the Doctor isn't trying to save us. He's experimenting on us. Viktor is covering for him."
                  },
