            {
              "step": 3,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "anne",
                "place": "store",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Anne, I need to know who's really running this island. Viktor? Or someone else?"
                  },
                  {
                    "speaker": "anne",
                    "line": "Viktor has the guns, but he doesn't have the answers. Everyone's talking about the experiments at the Outpost. The Doctor is the one pulling the strings."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I need to get in there. Do you have the key?"
                  },
                  {
                    "speaker": "anne",
                    "line": "I found this lab key in a crate of medical supplies last week. I was waiting for the right person to ask. Here."
                  }
                ]
              }
            },
            {
              "step": 4,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "lab_key_1",
                "place": "store"
              }
            },
            {
              "step": 5,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "store",
                "to": "village"
