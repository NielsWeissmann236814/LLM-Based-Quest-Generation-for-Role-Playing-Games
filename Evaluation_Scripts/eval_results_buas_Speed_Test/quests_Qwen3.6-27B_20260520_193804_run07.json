    "quest_data": {
      "chapter_id": "C2",
      "chapter_title": "The Puppeteer's Strings",
      "quest_type": "main",
      "required": true,
      "scale": "large",
      "quests": [
        {
          "quest_id": "Q2_1",
          "quest_title": "Infiltrating the Outpost",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 2,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "cave"
              }
            },
            {
              "step": 3,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "outpost_key_1",
                "place": "cave"
              }
            },
            {
              "step": 4,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "cave",
                "to": "village"
              }
            },
            {
              "step": 5,
              "action": "UNLOCK",
              "actor": "player",
              "parameters": {
                "key_item": "outpost_key_1",
                "target_place": "outpost1"
              }
            },
            {
              "step": 6,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "outpost2"
              }
            },
            {
              "step": 7,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "viktor",
                "place": "outpost2",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Viktor. I'm here to talk about what's happening on this island."
                  },
                  {
                    "speaker": "viktor",
                    "line": "You are here because I allow it. For now. The Doctor has his work to do, and I have my order to maintain."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Your order? You're pulling the strings, Viktor. You're using the outbreak to seize control."
                  },
                  {
                    "speaker": "viktor",
                    "line": "Chaos is the enemy of survival. I provide structure. The Doctor provides... progress. Together, we ensure that something remains of this world."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Your 'progress' is built on suffering. I'm going to stop you."
                  },
                  {
                    "speaker": "viktor",
                    "line": "You are one person. I am the authority here. Leave, or be removed."
                  }
                ]
              }
            }
          ]
        },
        {
          "quest_id": "Q2_2",
          "quest_title": "The Doctor's Legacy",
          "steps": [
            {
              "step": 8,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost3"
              }
            },
            {
              "step": 9,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "the_doctor",
                "place": "outpost3",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "The Doctor. I know what you're doing. And I know Viktor is funding it."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Observant. Yes, Viktor provides the resources. I provide the scientific advancement. It is a mutually beneficial arrangement."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Mutually beneficial? You're experimenting on people. This isn't science; it's cruelty."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Cruelty is a subjective term. I am preserving knowledge. If the village falls, my research survives. That is the priority."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I'm going to make sure your research ends today."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "You lack the capacity to understand the magnitude of what I have achieved. But do try. It will be... educational."
                  }
                ]
              }
            },
            {
              "step": 10,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "toolkit_1",
                "place": "outpost3"
              }
            },
            {
              "step": 11,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost3",
                "to": "outpost2"
              }
            },
            {
              "step": 12,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost1"
              }
            },
            {
              "step": 13,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "village"
              }
            }
          ]
        },
        {
          "quest_id": "Q2_3",
          "quest_title": "A Path to Freedom",
          "steps": [
            {
              "step": 14,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "dock"
              }
            },
            {
              "step": 15,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Mary. I have the toolkit you need. I also found some wood in the village."
                  },
                  {
                    "speaker": "mary",
                    "line": "Good. The boat is ready when you are. I've been waiting for someone with the skills to fix her."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Let's get her seaworthy. We might need to leave soon."
                  },
                  {
                    "speaker": "mary",
                    "line": "Aye. Better to have the option than to be trapped here when things go south."
                  }
                ]
              }
            },
            {
              "step": 16,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "dock",
                "to": "village"
              }
            },
            {
              "step": 17,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "wood_1",
                "place": "village"
              }
            },
            {
              "step": 18,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "dock"
              }
            },
            {
              "step": 19,
              "action": "REPAIR",
              "actor": "player",
              "parameters": {
                "toolkit_item": "toolkit_1",
                "wood_item": "wood_1",
                "target": "boat",
                "place": "dock"
              }
            },
            {
              "step": 20,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "The boat is fixed. When do we leave?"
                  },
                  {
                    "speaker": "mary",
                    "line": "Not yet. We need to be sure the path is clear. But knowing we can leave... that's a weight off my shoulders."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Agreed. We'll keep it ready. Just in case."
                  }
                ]
              }
            }
          ]
        }
      ]
    }
