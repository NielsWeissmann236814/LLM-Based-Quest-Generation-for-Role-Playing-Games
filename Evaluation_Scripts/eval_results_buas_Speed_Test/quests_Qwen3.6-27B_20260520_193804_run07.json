            },
            {
              "step": 2,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "graveyard"
              }
            },
            {
              "step": 3,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "linda",
                "place": "graveyard",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Linda? It's quiet out here. Too quiet."
                  },
                  {
                    "speaker": "linda",
                    "line": "Quiet is safe. Loud brings the dead. You're looking for something."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I need to get into the lab. Sarah is inside, but the door is locked."
                  },
                  {
                    "speaker": "linda",
                    "line": "The lab key. I saw it near the old headstones yesterday. Didn't touch it. Didn't want to draw attention."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Thanks, Linda. I'll be careful."
                  },
                  {
                    "speaker": "linda",
                    "line": "Carefulness is all we have left. Go."
                  }
                ]
              }
            },
            {
              "step": 4,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "lab_key_1",
                "place": "graveyard"
              }
            }
          ]
        },
        {
          "quest_id": "Q1_02",
          "quest_title": "Power to the People",
          "steps": [
