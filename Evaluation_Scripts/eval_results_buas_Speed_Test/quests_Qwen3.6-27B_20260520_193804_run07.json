      "quests": [
        {
          "quest_id": "Q1_01",
          "quest_title": "The Key in the Dark",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "safehouse",
                "to": "village"
