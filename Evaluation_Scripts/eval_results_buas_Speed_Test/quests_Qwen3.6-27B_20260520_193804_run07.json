    "quest_data": {
      "chapter_id": "C3",
      "chapter_title": "The Final Horizon",
      "quest_type": "main",
      "required": true,
      "scale": "large",
      "quests": [
        {
          "quest_id": "Q3_1",
          "quest_title": "Departure",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "dock",
                "to": "dock"
              }
            },
            {
              "step": 2,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Mary, I've heard there's a way off this island. The boat looks ready."
                  },
                  {
                    "speaker": "mary",
                    "line": "It is. Fixed it myself, bolt by bolt. But the sea doesn't care about your intentions. You ready to leave?"
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I am. This place is dying. I'm not staying to watch it rot."
                  },
                  {
                    "speaker": "mary",
                    "line": "Then you'd better get in. Tides wait for no one, and neither do I."
                  }
                ]
              }
            }
          ]
        }
      ]
    }
