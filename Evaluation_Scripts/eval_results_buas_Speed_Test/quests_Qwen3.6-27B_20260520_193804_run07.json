                "to": "laboratory"
              }
            },
            {
              "step": 7,
              "action": "UNLOCK",
              "actor": "player",
              "parameters": {
                "key_item": "lab_key_1",
                "target_place": "laboratory"
              }
            },
            {
              "step": 8,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "fuse_1",
                "place": "laboratory"
              }
            },
            {
              "step": 9,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 10,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "powerstation"
              }
            },
            {
              "step": 11,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "george",
                "place": "powerstation",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "George. The lab has no power. Sarah needs it to work on the cure."
                  },
                  {
                    "speaker": "george",
                    "line": "The grid is down. Main fuse blew three days ago. I've been waiting for a replacement."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I found one in the lab. It's ironic, isn't it? The solution was behind the locked door."
                  },
                  {
                    "speaker": "george",
                    "line": "Efficiency is rarely poetic. Hand it over. I'll restore the feed."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Here you go. Can you do it?"
                  },
                  {
                    "speaker": "george",
                    "line": "I was born for this. Stand back."
                  }
                ]
              }
            },
            {
              "step": 12,
              "action": "TURN_POWER_ON",
              "actor": "player",
              "parameters": {
                "fuse_item": "fuse_1",
                "place": "powerstation",
                "target_place": "laboratory"
              }
            }
          ]
        },
        {
          "quest_id": "Q1_03",
          "quest_title": "A Cure for the World",
          "steps": [
            {
              "step": 13,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "powerstation",
                "to": "village"
              }
            },
            {
              "step": 14,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "hospital1"
              }
            },
            {
              "step": 15,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital1",
                "to": "hospital2"
              }
            },
            {
              "step": 16,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "marcus",
                "place": "hospital2",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Marcus. I'm heading to the lab. I need the cure sample."
                  },
                  {
                    "speaker": "marcus",
                    "line": "It's on the table. Don't take long. The perimeter is getting thin."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I'll be quick. Thanks for holding the line."
                  },
                  {
                    "speaker": "marcus",
                    "line": "Just do your job. I'll do mine."
                  }
                ]
              }
            },
            {
              "step": 17,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "cure_sample_1",
                "place": "hospital2"
              }
            },
            {
              "step": 18,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital2",
                "to": "hospital1"
              }
            },
            {
              "step": 19,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital1",
                "to": "village"
              }
            },
            {
              "step": 20,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "laboratory"
              }
            },
            {
              "step": 21,
              "action": "SYNTHESIZE_CURE",
              "actor": "player",
              "parameters": {
                "place": "laboratory"
              }
            },
            {
              "step": 22,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah! I brought the sample. I synthesized the antidote."
                  },
                  {
                    "speaker": "sarah",
                    "line": "You... you did it? The power is on. The machine worked."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "We're going to fix this. Let me use the cure on you."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Please. I can feel it spreading. Hurry."
                  }
                ]
              }
            },
            {
              "step": 23,
              "action": "USE_CURE",
              "actor": "player",
              "parameters": {
                "item": "antidote_1",
                "target": "sarah"
              }
            }
          ]
        }
      ]
    }
