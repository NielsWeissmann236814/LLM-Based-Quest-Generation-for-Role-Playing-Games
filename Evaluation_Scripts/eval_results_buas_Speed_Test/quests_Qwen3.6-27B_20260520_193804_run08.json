                "to": "graveyard"
              }
            },
            {
              "step": 6,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "lab_key_1",
                "place": "graveyard"
              }
            }
          ]
        },
        {
          "quest_id": "Q1_C1_02",
          "quest_title": "Restoring Power",
          "steps": [
            {
              "step": 7,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "graveyard",
                "to": "village"
              }
            },
            {
              "step": 8,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "laboratory"
              }
            },
            {
              "step": 9,
              "action": "UNLOCK",
              "actor": "player",
              "parameters": {
                "key_item": "lab_key_1",
                "target_place": "laboratory"
              }
            },
            {
              "step": 10,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, I got in. You look terrible."
                  },
                  {
                    "speaker": "sarah",
                    "line": "The infection... it's progressing. I need to synthesize a cure, but the machines are dead. No power."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I can fix that. Where is the fuse?"
                  },
                  {
                    "speaker": "sarah",
                    "line": "It's right here on the desk. Take it to George at the powerstation. He can install it."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I'll get it done."
                  }
                ]
              }
            },
            {
              "step": 11,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "fuse_1",
                "place": "laboratory"
              }
            },
            {
              "step": 12,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 13,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "powerstation"
              }
            },
            {
              "step": 14,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "george",
                "place": "powerstation",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "George, I have a fuse for the lab. Can you install it?"
                  },
                  {
                    "speaker": "george",
                    "line": "Just give it here. I'll make the connection."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Here you go."
                  }
                ]
              }
            },
            {
              "step": 15,
              "action": "TURN_POWER_ON",
              "actor": "player",
              "parameters": {
                "fuse_item": "fuse_1",
                "place": "powerstation",
                "target_place": "laboratory"
              }
            }
          ]
        },
        {
          "quest_id": "Q1_C1_03",
          "quest_title": "The Cure Synthesis",
          "steps": [
            {
              "step": 16,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "powerstation",
                "to": "village"
              }
            },
            {
              "step": 17,
              "action": "MOVE",
