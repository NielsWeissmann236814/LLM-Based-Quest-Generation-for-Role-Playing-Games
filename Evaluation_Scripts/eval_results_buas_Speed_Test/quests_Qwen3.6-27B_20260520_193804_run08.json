              }
            },
            {
              "step": 24,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, I synthesized the cure. Let me give it to you."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Please... I can feel myself fading. Hurry."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Hold on."
                  }
                ]
              }
            },
            {
              "step": 25,
              "action": "USE_CURE",
              "actor": "player",
              "parameters": {
                "item": "antidote_1",
                "target": "sarah"
              }
            }
          ]
        }
      ]
    }
