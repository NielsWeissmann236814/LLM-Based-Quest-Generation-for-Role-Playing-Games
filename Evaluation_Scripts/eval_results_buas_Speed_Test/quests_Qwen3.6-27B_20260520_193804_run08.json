      "quests": [
        {
          "quest_id": "Q1_C1_01",
          "quest_title": "The Key in the Dark",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "safehouse",
                "to": "village"
              }
            },
            {
              "step": 2,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "store"
              }
            },
            {
              "step": 3,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "anne",
                "place": "store",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Anne, I need information. The village is crumbling. Is there a way to stop the infection?"
                  },
                  {
                    "speaker": "anne",
                    "line": "I hear rumors. Sarah at the lab might have answers, but her place is locked up tight. No power, no access."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "How do I get in?"
                  },
                  {
                    "speaker": "anne",
                    "line": "You need the lab key. Last I heard, it was tossed out near the graveyard. Dangerous trip, but it's your only lead."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I'll head to the graveyard."
                  }
                ]
              }
            },
            {
              "step": 4,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "store",
                "to": "village"
