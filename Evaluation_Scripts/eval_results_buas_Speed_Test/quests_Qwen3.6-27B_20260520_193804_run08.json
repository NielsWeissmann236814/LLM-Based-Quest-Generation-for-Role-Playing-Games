  {
    "model": "Qwen3.6-27B",
    "run": 8,
    "chapter_id": "C2",
    "quest_data": {
      "chapter_id": "C2",
      "chapter_title": "The Puppeteer's Strings",
      "quest_type": "main",
      "required": true,
      "scale": "large",
      "quests": [
        {
          "quest_id": "Q2_1",
          "quest_title": "Infiltrating the Outpost",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 2,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "cave"
              }
            },
            {
              "step": 3,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "outpost_key_1",
                "place": "cave"
              }
            },
            {
              "step": 4,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "cave",
                "to": "village"
              }
            },
            {
              "step": 5,
              "action": "UNLOCK",
              "actor": "player",
              "parameters": {
                "key_item": "outpost_key_1",
                "target_place": "outpost1"
              }
            },
            {
              "step": 6,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "outpost2"
              }
            },
            {
              "step": 7,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "viktor",
                "place": "outpost2",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Viktor. I'm not here to fight you right now."
                  },
                  {
                    "speaker": "viktor",
                    "line": "Then you are wasting my time. Leave, or be removed."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I know about the Doctor. I know you're using him. I want to see what he's building."
                  },
                  {
                    "speaker": "viktor",
                    "line": "Curiosity is a luxury you can no longer afford. But... perhaps you can be useful. Go to the lower levels. Observe. Do not interfere."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "If I find out you're lying, this changes everything."
                  },
                  {
                    "speaker": "viktor",
                    "line": "Go."
                  }
                ]
              }
            },
            {
              "step": 8,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost3"
              }
            }
          ]
        },
        {
          "quest_id": "Q2_2",
          "quest_title": "The Doctor's Truth",
          "steps": [
            {
              "step": 9,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "the_doctor",
                "place": "outpost3",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Doctor. Viktor says I can observe. I want to know what you're really doing here."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Observation is the first step toward understanding. Viktor provides resources; I provide direction. We are curating the future."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Curing? Or controlling?"
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Order requires control. The chaos outside is inefficient. My research ensures that when society rebuilds, it does so under rational management. Not mob rule."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "You're using the outbreak as an excuse to seize power."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "I am using the outbreak to prove that humanity needs guidance. Take this toolkit. It is of no use to me here. Perhaps it will help you survive your... moral crusade."
                  }
                ]
              }
            },
            {
              "step": 10,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "toolkit_1",
                "place": "outpost3"
              }
            },
            {
              "step": 11,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost3",
                "to": "outpost2"
              }
            },
            {
              "step": 12,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost1"
              }
            },
            {
              "step": 13,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "village"
              }
            }
          ]
        },
        {
          "quest_id": "Q2_3",
          "quest_title": "The Escape Route",
          "steps": [
            {
              "step": 14,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "dock"
              }
            },
            {
              "step": 15,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Mary. I've been to the Outpost. Viktor and the Doctor are planning something big. We need a way out."
                  },
                  {
                    "speaker": "mary",
                    "line": "I've been waiting for someone to say that. My boat is sitting right there. Broken, but fixable."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I have the toolkit. I need wood."
                  },
                  {
                    "speaker": "mary",
                    "line": "There's scrap wood in the village. It's dangerous, but if you can get it, I'll help you load it. Just get the boat running."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Consider it done."
                  }
                ]
              }
            },
            {
              "step": 16,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "dock",
                "to": "village"
              }
            },
            {
              "step": 17,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "wood_1",
                "place": "village"
              }
            },
            {
              "step": 18,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "dock"
              }
            },
            {
              "step": 19,
              "action": "REPAIR",
              "actor": "player",
              "parameters": {
                "toolkit_item": "toolkit_1",
                "wood_item": "wood_1",
                "target": "boat",
                "place": "dock"
              }
            },
            {
              "step": 20,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "The boat is fixed. Are you ready to leave?"
                  },
                  {
                    "speaker": "mary",
                    "line": "I've been ready for weeks. But I won't leave everyone behind. Not yet. We need to make sure the others know what's happening."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Agreed. We expose Viktor and the Doctor first."
                  },
                  {
                    "speaker": "mary",
                    "line": "Good. Then we sail. I'll keep the engine warm."
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  },
  {
    "model": "Qwen3.6-27B",
    "run": 8,
    "chapter_id": "C3",
    "quest_data": {
      "chapter_id": "C3",
      "chapter_title": "Departure",
      "quest_type": "main",
      "required": true,
      "scale": "large",
      "quests": [
        {
          "quest_id": "Q3_1",
          "quest_title": "The Way Out",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "dock",
                "to": "village"
              }
            },
            {
              "step": 2,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "anne",
                "place": "store",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Anne, I've heard there might be a way off the island. Mary's boat is fixed, but I need to know if anyone else is ready to leave."
                  },
                  {
                    "speaker": "anne",
                    "line": "Mary has her boat, yes. But a boat is just wood and engine. You need people who want to survive, not just hide. I've kept the store stocked for those who stay, but my heart is with those who leave."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Who's ready? Who has the means?"
                  },
                  {
                    "speaker": "anne",
                    "line": "Sarah has been working on a cure in the lab, but she needs power to synthesize it. George manages the grid, but he's stubborn. Marcus is holding the hospital, but he's fortified it tight. Linda... Linda just wants to be left alone. If you want to leave, you'll need to decide who comes with you, and what you leave behind."
                  }
                ]
              }
            },
            {
              "step": 3,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "store"
              }
            },
            {
              "step": 4,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "wood_1",
                "place": "store"
              }
            },
            {
              "step": 5,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "store",
                "to": "village"
              }
            },
            {
              "step": 6,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "wood_2",
                "place": "village"
              }
            },
            {
              "step": 7,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "wood_3",
                "place": "village"
              }
            },
            {
              "step": 8,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "hospital1"
              }
            },
            {
              "step": 9,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital1",
                "to": "hospital2"
              }
            },
            {
              "step": 10,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "marcus",
                "place": "hospital2",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Marcus, the island is falling apart. Mary's boat is ready. I'm leaving."
                  },
                  {
                    "speaker": "marcus",
                    "line": "I've held this line for weeks. You think I don't know it's over? I'm staying. Someone has to watch the rear."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "You don't have to die here. Take this wood, fortify the place properly, and maybe you'll make it. Or come with us."
                  },
                  {
                    "speaker": "marcus",
                    "line": "My duty is here. Take the wood. And go. Live."
                  }
                ]
              }
            },
            {
              "step": 11,
              "action": "GIVE_ITEM",
              "actor": "player",
              "parameters": {
                "item": "wood_1",
                "target": "marcus",
                "place": "hospital2"
              }
            },
            {
              "step": 12,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital2",
                "to": "hospital1"
              }
            },
            {
              "step": 13,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital1",
                "to": "village"
              }
            },
            {
              "step": 14,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "powerstation"
              }
            },
            {
              "step": 15,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "george",
                "place": "powerstation",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "George, Sarah needs power in the lab to finish the cure. Can you route it?"
                  },
                  {
                    "speaker": "george",
                    "line": "The lines are stable. I can send power anywhere. But why? If you're leaving, why fix the lab?"
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Because if we leave with a cure, we leave with hope. If we leave with nothing, we're just refugees. Help Sarah."
                  },
                  {
                    "speaker": "george",
                    "line": "Understood. I'll keep the grid running. It's efficient. It's logical. Go."
                  }
                ]
              }
            },
            {
              "step": 16,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "powerstation",
                "to": "village"
              }
            },
            {
              "step": 17,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "laboratory"
              }
            },
            {
              "step": 18,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, George is keeping the power on. Can you synthesize the cure now?"
                  },
                  {
                    "speaker": "sarah",
                    "line": "I have the sample. I have the power. But I need to test it. If I give it to you, you can use it on anyone infected. But I... I am not infected. I am not leaving."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Why stay?"
                  },
                  {
                    "speaker": "sarah",
                    "line": "Because the work isn't done. The data is here. If you leave, take the cure. Save who you can. I will finish the rest."
                  }
                ]
              }
            },
            {
              "step": 19,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "cure_sample_1",
                "place": "laboratory"
              }
            },
            {
              "step": 20,
              "action": "SYNTHESIZE_CURE",
              "actor": "player",
              "parameters": {
                "place": "laboratory"
              }
            },
            {
              "step": 21,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 22,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "dock"
              }
            },
            {
              "step": 23,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Mary, the boat is ready. I have the cure. Who's coming?"
                  },
                  {
                    "speaker": "mary",
                    "line": "I'm coming. I've waited long enough. Who else?"
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Just us. Sarah stays. Marcus stays. George stays. Anne stays. It's time to go."
                  },
                  {
                    "speaker": "mary",
                    "line": "Then let's go. The tide waits for no one."
                  }
                ]
              }
            },
            {
              "step": 24,
              "action": "USE_CURE",
              "actor": "player",
              "parameters": {
                "item": "antidote_1",
                "target": "mary"
              }
            },
            {
              "step": 25,
              "action": "REPAIR",
