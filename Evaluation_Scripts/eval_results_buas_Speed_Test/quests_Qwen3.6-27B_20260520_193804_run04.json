              "actor": "player",
              "parameters": {
                "target": "the_doctor",
                "place": "outpost3",
                "dialogue_content": [
                  {
                    "speaker": "player",
                    "line": "You're the one pulling the strings. I know about your experiments."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "And you are an observer who has wandered into the laboratory. How... unfortunate."
                  },
                  {
                    "speaker": "player",
                    "line": "Viktor is just your muscle. You're the real threat."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Viktor provides security. I provide the means of control. We are symbiotic."
                  },
                  {
                    "speaker": "player",
                    "line": "Your research is killing people."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "My research is evolving them. You are merely collateral in the pursuit of legacy."
                  },
                  {
                    "speaker": "player",
                    "line": "I'm taking your toolkit. Consider this an intervention."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Take it. It changes nothing. The data is already secured."
                  }
                ]
              }
            },
            {
              "step": 10,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "toolkit_1",
                "place": "outpost3"
