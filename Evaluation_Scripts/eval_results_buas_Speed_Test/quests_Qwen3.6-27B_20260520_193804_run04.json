              "step": 7,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "viktor",
                "place": "outpost2",
                "dialogue_content": [
                  {
                    "speaker": "player",
                    "line": "I need to know what you're doing here, Viktor."
                  },
                  {
                    "speaker": "viktor",
                    "line": "Maintaining order. Something you clearly lack the discipline to understand."
                  },
                  {
                    "speaker": "player",
                    "line": "Order? You're hoarding resources and blocking people."
                  },
                  {
                    "speaker": "viktor",
                    "line": "I am securing the future. The weak perish; the strong survive. It is simple biology."
                  },
                  {
                    "speaker": "player",
                    "line": "It's tyranny. And I'm going to stop it."
                  },
                  {
                    "speaker": "viktor",
                    "line": "You are a variable I have not yet calculated. Do not become a problem."
                  }
                ]
