      "quests": [
        {
          "quest_id": "q1_c1",
          "quest_title": "The Storekeeper's Warning",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "safehouse",
                "to": "village"
            },
            {
              "step": 2,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "store"
              }
            },
            {
              "step": 3,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "anne",
                "place": "store",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "The village feels quieter than usual. Is everyone hiding?"
                  },
                  {
                    "speaker": "anne",
                    "line": "Hiding is the smart play right now. But the quiet isn't just fear; it's the dark. The lights at the hospital and the lab went out days ago. George is down at the powerstation, but he's stuck without a fuse."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "A fuse? Where would one find that?"
                  },
                  {
                    "speaker": "anne",
                    "line": "I hear whispers, but I don't deal in rumors. However, I know Sarah. She's at the lab, trying to work on a cure for the infected. If she can't see her instruments, she can't save anyone. You need to get power to that lab. The fuse is likely inside, but the door is locked tight."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "So I need the fuse to get the power, but the fuse is inside the locked lab?"
                  },
                  {
                    "speaker": "anne",
                    "line": "A nasty circle, isn't it? The graveyard holds the key to the lab. But be careful, the dead don't stay put there. Get the key, get the fuse, get the power. That's the only way to keep the village from dying in the dark."
                  }
                ]
              }
            }
          ]
        },
        {
          "quest_id": "q2_c1",
          "quest_title": "The Key in the Graveyard",
          "steps": [
