              "step": 4,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "outpost_key_1",
                "place": "cave"
              }
            },
            {
              "step": 5,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "cave",
                "to": "village"
              }
            },
            {
              "step": 6,
              "action": "UNLOCK",
              "actor": "player",
              "parameters": {
                "key_item": "outpost_key_1",
                "target_place": "outpost1"
              }
            },
            {
              "step": 7,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "outpost2"
              }
            },
            {
              "step": 8,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "viktor",
                "place": "outpost2",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "I'm looking for answers about the island's collapse. Someone is pulling strings."
                  },
                  {
                    "speaker": "viktor",
                    "line": "Answers are a luxury. Order is the necessity. I provide the order."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Order built on fear? The Doctor is using the outbreak for experiments."
                  },
                  {
                    "speaker": "viktor",
                    "line": "The Doctor is a variable I am monitoring. His ambition is... contained."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Contained? He's in the lower levels of Outpost 3. I'm going in."
                  },
                  {
                    "speaker": "viktor",
                    "line": "Then you walk into a trap. But if you survive, perhaps you'll understand the cost of control."
                  }
                ]
              }
            },
            {
              "step": 9,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost3"
              }
            },
            {
              "step": 10,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "the_doctor",
                "place": "outpost3",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Your research is a disaster. People are dying because of you."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Dying is a biological constant. Evolution is the variable. I am merely observing the rate of change."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I've seen the notes. You're not just observing; you're accelerating it."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Acceleration requires a catalyst. Your arrival is timely, though your sentiment is inefficient."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I'm here to stop you. Where is the cure sample?"
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "The sample is irrelevant without the synthesis protocol. But if you seek the sample, it is in the laboratory. Access is restricted, of course."
                  }
                ]
              }
            }
          ]
        },
        {
          "quest_id": "Q2_2",
          "quest_title": "The Key to the Lab",
          "steps": [
            {
              "step": 11,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost3",
                "to": "outpost2"
              }
            },
            {
              "step": 12,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost1"
              }
            },
            {
              "step": 13,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "village"
              }
            },
            {
              "step": 14,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "store"
              }
            },
            {
              "step": 15,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "anne",
                "place": "store",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Anne, I need to get into the laboratory. The Doctor has something there I need."
                  },
                  {
                    "speaker": "anne",
                    "line": "The lab is locked tight. Viktor has the main key, but I've heard whispers of a spare."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "A spare? Where would it be?"
                  },
                  {
                    "speaker": "anne",
                    "line": "Old habits. George kept a spare in his gear before the grid went unstable. He's at the powerstation. He might not want to give it up, but he's a man of duty."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Thanks, Anne. I'll go see him."
                  },
                  {
                    "speaker": "anne",
                    "line": "Be careful. George doesn't like interruptions, and Viktor is watching."
                  }
                ]
              }
            },
            {
              "step": 16,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "store",
                "to": "village"
              }
            },
            {
              "step": 17,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "powerstation"
              }
            },
            {
              "step": 18,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "george",
                "place": "powerstation",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "George, I need the spare key to the laboratory."
                  },
                  {
                    "speaker": "george",
                    "line": "The lab is a dead end. No power, no use. Why do you need it?"
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "The Doctor is there. He has a cure sample. We need to get it to Sarah."
                  },
                  {
                    "speaker": "george",
                    "line": "Sarah is in the lab. If the power is on, she can work. The power is on now, thanks to my efforts."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Then I need the key to get to her. Please."
                  },
                  {
                    "speaker": "george",
                    "line": "Fine. It's in my pocket. Take it. Don't waste time."
                  }
                ]
              }
            },
            {
              "step": 19,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "powerstation",
                "to": "village"
              }
            },
            {
              "step": 20,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "laboratory"
              }
            }
          ]
        },
        {
          "quest_id": "Q2_3",
          "quest_title": "Synthesis and Confrontation",
          "steps": [
            {
              "step": 21,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, the Doctor is hoarding the cure sample. I have the key now."
                  },
                  {
                    "speaker": "sarah",
                    "line": "I know. I've been trying to breach his security from the inside, but I lack the physical access."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I can get the sample. But I need you to synthesize it immediately."
                  },
                  {
                    "speaker": "sarah",
                    "line": "The machine is ready. Power is stable. Give me the sample, and I'll turn it into an antidote."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I'll go to the Doctor and get it. Wait here."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Hurry. The sample degrades if left too long."
                  }
                ]
              }
            },
            {
              "step": 22,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 23,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "outpost1"
              }
            },
            {
              "step": 24,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "outpost2"
              }
            },
            {
              "step": 25,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost3"
              }
            },
            {
              "step": 26,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "the_doctor",
                "place": "outpost3",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Give me the cure sample, Doctor. Now."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "You are persistent. Very well. The sample is on the table. Take it and leave."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "This isn't over. I'll destroy your research."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Destruction is merely a change in state. Go. I have other variables to attend to."
                  }
                ]
              }
            },
            {
              "step": 27,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "cure_sample_1",
                "place": "outpost3"
              }
            },
            {
              "step": 28,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost3",
                "to": "outpost2"
              }
            },
            {
              "step": 29,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost1"
              }
            },
            {
              "step": 30,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "village"
              }
            },
            {
              "step": 31,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "laboratory"
              }
            },
            {
              "step": 32,
              "action": "SYNTHESIZE_CURE",
              "actor": "player",
              "parameters": {
                "place": "laboratory"
              }
            }
          ]
        }
      ]
    }
