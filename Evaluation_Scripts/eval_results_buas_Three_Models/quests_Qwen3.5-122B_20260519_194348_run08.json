              "actor": "player",
              "parameters": {
                "key_item": "lab_key_1",
                "target_place": "laboratory"
              }
            },
            {
              "step": 10,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "fuse_1",
                "place": "laboratory"
              }
            },
            {
              "step": 11,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, the lab is dark. You're working blind."
                  },
                  {
                    "speaker": "sarah",
                    "line": "I can hear the hum of the generator is gone. I have the sample, but without the machine running, it's just a vial of useless fluid. I can't synthesize the cure without power."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I have a fuse. George at the powerstation needs it to bring the grid back online."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Then take it. The powerstation is in the village. Once the power is on, come back here. We have work to do. The village is dying, and we are the only ones who can stop it."
                  }
                ]
              }
            }
          ]
        },
        {
          "quest_id": "q4_c1",
          "quest_title": "Restoring the Spark",
          "steps": [
