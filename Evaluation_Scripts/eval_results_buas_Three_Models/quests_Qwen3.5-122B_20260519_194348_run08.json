            {
              "step": 13,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "powerstation"
              }
            },
            {
              "step": 14,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "george",
                "place": "powerstation",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "George, I found the fuse."
                  },
                  {
                    "speaker": "george",
                    "line": "Finally. The grid has been dead for too long. The lab needs this more than anything else. Hand it over."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Here. Get the lights back on."
                  },
                  {
                    "speaker": "george",
                    "line": "Installing now. Power is routing to the main line. The lab should come online immediately. Good work."
                  }
                ]
              }
            },
            {
              "step": 15,
              "action": "TURN_POWER_ON",
              "actor": "player",
              "parameters": {
                "fuse_item": "fuse_1",
                "place": "powerstation",
                "target_place": "laboratory"
              }
            }
          ]
        },
