            },
            {
              "step": 23,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 24,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "hospital1"
              }
            },
            {
              "step": 25,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital1",
                "to": "hospital2"
              }
            },
            {
              "step": 26,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "hospital2",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, I'm back. The cure is synthesized."
                  },
                  {
                    "speaker": "sarah",
                    "line": "You're too late. I was infected before you could get the power back. The infection is spreading fast in my system."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I have the antidote. Let me use it on you."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Do it. If I can be saved, then the cure works. If I die, then we have failed. Administer the antidote."
                  }
                ]
              }
            },
            {
              "step": 27,
              "action": "USE_CURE",
              "actor": "player",
              "parameters": {
                "item": "antidote_1",
                "target": "sarah"
              }
            }
          ]
        }
      ]
