  {
    "model": "Qwen3.5-122B",
    "run": 8,
    "chapter_id": "C3",
    "quest_data": {
      "chapter_id": "C3",
      "chapter_title": "The Final Voyage",
      "quest_type": "main",
      "required": true,
      "scale": "large",
      "quests": [
        {
          "quest_id": "C3_Q1",
          "quest_title": "The Doctor's Legacy",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 2,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "outpost1"
              }
            },
            {
              "step": 3,
              "action": "UNLOCK",
              "actor": "player",
              "parameters": {
                "key_item": "outpost_key_1",
                "target_place": "outpost1"
              }
            },
            {
              "step": 4,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "outpost2"
              }
            },
            {
              "step": 5,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost3"
              }
            },
            {
              "step": 6,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "the_doctor",
                "place": "outpost3",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "The Doctor. Your time is up. Viktor's gone, and the village is waiting for you."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Time is a construct, isn't it? Viktor was a variable I could not control, but you... you are the final variable."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I'm not here to debate your philosophy. I'm here to make sure your research doesn't end with you."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "A surprising sentiment. I have the data, but the cure sample... that is the key to the next phase. It is currently in my possession, though you may have already seen it."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I have the antidote. I don't need your sample, but I need to know if you have anything else of value before I leave."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Value is relative. To you, it is a tool for survival. To me, it was a legacy. Take the toolkit from the corner; it was useless to me in this final hour. Consider it a parting gift."
                  }
                ]
              }
            },
            {
              "step": 7,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "toolkit_1",
                "place": "outpost3"
              }
            }
          ]
