              "actor": "player",
              "parameters": {
                "item": "lab_key_1",
                "place": "graveyard"
              }
            }
          ]
        },
        {
          "quest_id": "q3_c1",
          "quest_title": "The Silent Laboratory",
          "steps": [
            {
              "step": 7,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "graveyard",
                "to": "village"
