              }
            },
            {
              "step": 7,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "dock"
              }
            },
            {
              "step": 8,
              "action": "REPAIR",
              "actor": "player",
              "parameters": {
                "toolkit_item": "toolkit_1",
                "wood_item": "wood_1",
                "target": "boat",
                "place": "dock"
              }
            }
          ]
        },
        {
          "quest_id": "C3_Q2",
          "quest_title": "A Cure for the Journey",
          "steps": [
            {
              "step": 9,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "dock",
                "to": "village"
              }
            },
            {
              "step": 10,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, the boat is ready. But we can't leave anyone behind if they're sick. Do you have the cure sample?"
                  },
                  {
                    "speaker": "Sarah",
                    "line": "I do. The synthesis machine is primed, but I need the power to be stable. Is George at the station?"
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "He is. I can get the power running if you have the sample ready."
                  },
                  {
                    "speaker": "Sarah",
                    "line": "Then go. Turn the power on at the station, bring me the sample, and I'll synthesize the antidote before we board."
                  }
                ]
              }
            },
            {
              "step": 11,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "powerstation"
              }
            },
            {
              "step": 12,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "george",
                "place": "powerstation",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "George, we're leaving. The boat is fixed, but Sarah needs the lab powered up to make the cure."
                  },
                  {
                    "speaker": "George",
                    "line": "I've been holding the grid together with a prayer and some duct tape. If you have a fuse, I can route the power to the lab."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I don't have a fuse. Do you know where one is?"
                  },
                  {
                    "speaker": "George",
                    "line": "The old generator shed near the graveyard. It's risky, but if you find it, bring it here. I'll handle the rest."
                  }
                ]
              }
            },
            {
              "step": 13,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "powerstation",
                "to": "village"
              }
            },
            {
              "step": 14,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "graveyard"
              }
            },
            {
              "step": 15,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "fuse_1",
                "place": "graveyard"
              }
            },
            {
              "step": 16,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "graveyard",
                "to": "village"
              }
            },
            {
