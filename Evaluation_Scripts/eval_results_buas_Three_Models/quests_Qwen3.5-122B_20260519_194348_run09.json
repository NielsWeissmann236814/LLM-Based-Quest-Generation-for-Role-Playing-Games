            {
              "step": 2,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Mary, I'm here to help. The boat won't move without a fix, and I know you need to get out."
                  },
                  {
                    "speaker": "Mary",
                    "line": "Took you long enough. The hull's cracked and the engine's dead. I've got the will, but I lack the means."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I have a toolkit. If you can point me to the wood, I can patch the hull and get the engine running."
                  },
                  {
                    "speaker": "Mary",
                    "line": "Wood's in the village, scattered near the square. Bring it back here, use that toolkit, and we might just make it to the mainland."
                  }
                ]
              }
            },
            {
              "step": 3,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
