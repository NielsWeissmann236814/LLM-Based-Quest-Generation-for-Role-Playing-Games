      "quests": [
        {
          "quest_id": "C3_Q1",
          "quest_title": "The Power of Escape",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "powerstation",
                "to": "village"
