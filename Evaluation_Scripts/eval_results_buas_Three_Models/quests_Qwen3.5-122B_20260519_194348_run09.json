              "parameters": {
                "from": "village",
                "to": "powerstation"
              }
            },
            {
              "step": 18,
              "action": "TURN_POWER_ON",
              "actor": "player",
              "parameters": {
                "fuse_item": "fuse_1",
                "place": "powerstation",
                "target_place": "laboratory"
              }
            },
            {
              "step": 19,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "powerstation",
                "to": "village"
              }
            },
            {
              "step": 20,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "laboratory"
              }
            },
            {
              "step": 21,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "cure_sample_1",
                "place": "laboratory"
              }
            },
            {
              "step": 22,
              "action": "SYNTHESIZE_CURE",
              "actor": "player",
              "parameters": {
                "place": "laboratory"
              }
            },
            {
              "step": 23,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 24,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "dock"
              }
            },
            {
              "step": 25,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Mary, the cure is synthesized. I have the antidote ready."
                  },
                  {
                    "speaker": "Mary",
                    "line": "Good. We can't leave anyone sick behind. Get everyone on board, and I'll cast off."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "It's time to go. The island is done with us."
                  },
                  {
                    "speaker": "Mary",
                    "line": "Then let's make sure we're the ones who survive it. All aboard."
                  }
                ]
              }
            }
          ]
        }
