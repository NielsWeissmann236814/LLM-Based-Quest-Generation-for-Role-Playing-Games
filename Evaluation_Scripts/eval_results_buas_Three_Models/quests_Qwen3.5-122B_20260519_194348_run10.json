                "place": "powerstation",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "George, the boat is fixed, but we need fuel. I heard you have a line on the generator."
                  },
                  {
                    "speaker": "george",
                    "line": "Fuel is irrelevant if the grid is dead. The main line to the dock is severed. I can reroute it, but I need a fuse."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I don't have one. Where can I find it?"
                  },
                  {
                    "speaker": "george",
                    "line": "Check the old supply crates in the village or the outpost. If you find a fuse, bring it here. I'll handle the rest."
                  }
                ]
              }
            },
            {
              "step": 15,
              "action": "MOVE",
              "actor": "player",
