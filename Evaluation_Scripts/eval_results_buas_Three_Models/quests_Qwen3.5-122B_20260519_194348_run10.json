              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Mary, George needs a fuse to power the dock. I found this wood, but I'm short on fuses."
                  },
                  {
                    "speaker": "mary",
                    "line": "Wood won't start an engine. I saw a crate near the safehouse that might have what George needs. Go check. I'll stay here and keep watch."
