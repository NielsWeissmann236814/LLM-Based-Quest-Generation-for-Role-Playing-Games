              "parameters": {
                "target": "george",
                "place": "powerstation",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "George, the lab has no power. Sarah can't work without it."
                  },
                  {
                    "speaker": "george",
                    "line": "I know. The grid is dead. I have the capacity to fix it, but I lack the component. Do you have a fuse?"
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Not yet. But I know where to find one. Where is it located?"
                  },
                  {
                    "speaker": "george",
                    "line": "In the lab. It's ironic, isn't it? The cure is inside, but the power to make it is locked out. Find the fuse, bring it here, and I'll get the lights on."
                  }
