            {
              "step": 10,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Mary, I've got the toolkit and the wood. Let's get this boat fixed."
                  },
                  {
                    "speaker": "mary",
                    "line": "About time. I've been staring at this hull for three days. Hand it over. If we can get the engine running, we might actually make it to the mainland before the tide turns."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I'm not leaving without a clear path. Is the engine sound?"
                  },
                  {
                    "speaker": "mary",
                    "line": "It's a stubborn beast, but she's got heart. Just give me the materials. I'll do the rest."
                  }
                ]
              }
            },
