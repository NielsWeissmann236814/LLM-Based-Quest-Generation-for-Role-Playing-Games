              "parameters": {
                "item": "cure_sample_1",
                "place": "hospital2"
              }
            },
            {
              "step": 24,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital2",
                "to": "hospital1"
              }
            },
            {
              "step": 25,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital1",
                "to": "village"
              }
            },
            {
              "step": 26,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
