        },
        {
          "quest_id": "Q1_5",
          "quest_title": "The First Cure",
          "steps": [
            {
              "step": 28,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "I've synthesized the cure. It's ready."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Finally. I've been fighting the infection for days. Please, administer it. If I recover, we can save the others."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Hold still, Sarah. This will make you better."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Thank you. The fever is already receding. We have a chance now."
                  }
                ]
              }
            },
