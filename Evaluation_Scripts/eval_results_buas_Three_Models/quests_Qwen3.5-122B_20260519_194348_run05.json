            {
              "step": 3,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "anne",
                "place": "store",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "The village is dying, Anne. People are sick, and the panic is setting in. Do you know what's happening?"
                  },
                  {
                    "speaker": "anne",
                    "line": "I've seen the symptoms. It's the same fever that took the first wave. But this time, it's spreading faster. I've heard whispers from Sarah in the lab, though she hasn't come out in days."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah? The lab is locked and dark. How is she working on anything?"
                  },
                  {
                    "speaker": "anne",
                    "line": "She's trapped in there, or so I think. The power is out, and the door won't budge without a key. If there's a cure to be found, it's in that lab. But you'll need to find the key to get in."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Where would a key to a secret lab be hidden in a place like this?"
                  },
                  {
                    "speaker": "anne",
                    "line": "People hide things where they think no one will look. Or where they've already lost everything. Try the graveyard. It's quiet there, and the dead don't ask questions."
                  }
                ]
              }
            }
          ]
        },
        {
          "quest_id": "Q1_2",
          "quest_title": "Key of the Dead",
          "steps": [
