      "quests": [
        {
          "quest_id": "Q1_1",
          "quest_title": "The Store's Intel",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "safehouse",
                "to": "village"
