            {
              "step": 8,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "powerstation"
              }
            },
            {
              "step": 9,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "george",
                "place": "powerstation",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "George, the lab is dead. Sarah needs power to synthesize a cure."
                  },
                  {
                    "speaker": "george",
                    "line": "The grid is down. I can fix the station, but I need a fuse. The main breaker blew out weeks ago."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I don't have a fuse. Do you know where one might be?"
                  },
                  {
                    "speaker": "george",
                    "line": "Sarah kept spares in her lab. But if the power is out, you can't get in to get them. It's a catch-22. Unless... you found a way to open the door."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I have the lab key. But I still need the fuse to turn the power on for the lab."
                  },
                  {
                    "speaker": "george",
                    "line": "Then go to the lab. Unlock it, grab the fuse, and bring it back here. Once I have it, I can restore power to the whole grid, including the lab."
                  }
                ]
              }
            },
            {
              "step": 10,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "powerstation",
