              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Mary, the island is burning. I heard there's a way off if we can fix this boat."
                  },
                  {
                    "speaker": "mary",
                    "line": "Aye, the hull's breached and the engine's dead. I've got the will, but I don't have the wood or the tools to patch her up."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I have a toolkit. I saw wood back in the village. If I bring you those, can you get us out?"
                  },
                  {
                    "speaker": "mary",
                    "line": "If you bring the wood and the kit, I'll have her seaworthy in an hour. But we only have room for one more passenger besides me. You decide who goes."
                  }
                ]
              }
            }
          ]
        },
        {
          "quest_id": "Q_C3_02",
          "quest_title": "Scavenging the Village",
          "steps": [
