        },
        {
          "quest_id": "Q1_3",
          "quest_title": "Restoring the Spark",
          "steps": [
            {
              "step": 7,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "graveyard",
                "to": "village"
