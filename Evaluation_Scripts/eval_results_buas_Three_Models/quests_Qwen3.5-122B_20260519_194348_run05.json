              "step": 7,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "dock"
              }
            }
          ]
        },
        {
          "quest_id": "Q_C3_03",
          "quest_title": "Setting Sail",
          "steps": [
            {
              "step": 8,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "I'm back. Here's the wood and I have my toolkit."
                  },
                  {
                    "speaker": "mary",
                    "line": "Good. Hand them over. Let's see if we can make this tin can float one last time."
                  }
                ]
              }
            },
            {
              "step": 9,
              "action": "REPAIR",
              "actor": "player",
              "parameters": {
                "toolkit_item": "toolkit_1",
                "wood_item": "wood_1",
                "target": "boat",
                "place": "dock"
              }
            },
            {
              "step": 10,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "mary",
                    "line": "She's solid. Engine's humming. We can leave now."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Let's go. Before the others arrive or the island falls completely."
                  },
                  {
                    "speaker": "mary",
                    "line": "Hold on tight. This is the last time I look back at this hellhole."
                  }
                ]
              }
            }
          ]
