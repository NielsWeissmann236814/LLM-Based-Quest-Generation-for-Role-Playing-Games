        {
          "quest_id": "Q1_4",
          "quest_title": "The Cure Within",
          "steps": [
            {
              "step": 17,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "powerstation",
                "to": "village"
              }
            },
            {
              "step": 18,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "laboratory"
              }
            },
            {
              "step": 19,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, the power is back. I have the fuse installed."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Excellent. The machines are humming again. I've been analyzing the pathogen, but I need a sample to synthesize the antidote."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I saw a sample in the hospital. Is that what you need?"
                  },
                  {
                    "speaker": "sarah",
                    "line": "Yes, cure_sample_1. It's the only viable culture we have. Bring it here, and I can synthesize the cure immediately. But be quick; my condition is deteriorating."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I'll get it. Stay safe."
                  }
                ]
              }
            },
            {
              "step": 20,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
