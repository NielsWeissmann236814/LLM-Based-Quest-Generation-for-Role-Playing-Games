              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "the_doctor",
                "place": "outpost1",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Doctor, I've been investigating the outbreak. I think you might know more than you're letting on."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "I'm just trying to understand the virus, find a cure. I don't know what you're insinuating."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I'm not insinuating anything. I just want the truth. Are you working with someone to control the outbreak?"
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "I'm working alone. But I do have a patron who provides me with resources. That's all I can say."
                  }
                ]
              }
            }
          ]
        }
