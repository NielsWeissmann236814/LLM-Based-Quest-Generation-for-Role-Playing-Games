              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, I've been thinking. We need to secure this laboratory. It's one of the few safe places left."
                  },
                  {
                    "speaker": "sarah",
                    "line": "I agree. But we need to be careful. If someone is indeed controlling the outbreak, they may try to sabotage our efforts."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I've picked up some wood from the village. Maybe we can use it to fortify the laboratory?"
                  },
                  {
                    "speaker": "sarah",
                    "line": "That's a good idea. Let's get to work."
                  }
                ]
              }
            },
            {
              "step": 7,
              "action": "FORTIFY",
              "actor": "player",
              "parameters": {
                "wood_item": "wood_1",
                "place": "laboratory"
              }
            }
          ]
        },
        {
          "quest_id": "Q3",
          "quest_title": "Investigating the Outpost",
          "steps": [
