              "step": 4,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "wood_1",
                "place": "village"
              }
            }
          ]
        },
        {
          "quest_id": "Q2",
          "quest_title": "Securing the Laboratory",
          "steps": [
            {
              "step": 5,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "laboratory"
