                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Anne, Sarah is cured. The village has a chance now."
                  },
                  {
                    "speaker": "anne",
                    "line": "Finally. A victory we can actually celebrate. But victory means nothing if we're surrounded by the dead."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "We need to make the safehouse and the store defensible. I saw wood in the village."
                  },
                  {
                    "speaker": "anne",
                    "line": "Then get that wood and fortify the store. I'll keep the inventory ready. Don't die out there."
                  }
                ]
              }
            },
