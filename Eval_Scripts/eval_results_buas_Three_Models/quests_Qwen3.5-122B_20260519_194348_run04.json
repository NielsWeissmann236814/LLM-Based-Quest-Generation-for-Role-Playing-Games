                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, the power is back on. I have the cure sample from the hospital."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Good. The synthesis machine is online. Hand me the sample, and I'll begin the process immediately."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I can't give it to you directly, but I can synthesize it myself if you guide me."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Understood. Proceed with the synthesis. I will monitor the parameters from here. Do not fail."
                  }
                ]
              }
            },
            {
              "step": 20,
              "action": "SYNTHESIZE_CURE",
              "actor": "player",
              "parameters": {
                "place": "laboratory"
              }
            },
