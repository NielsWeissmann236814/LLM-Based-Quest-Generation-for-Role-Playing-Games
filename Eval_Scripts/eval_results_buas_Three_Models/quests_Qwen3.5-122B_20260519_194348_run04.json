              "step": 21,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "It's done. I have the antidote. You need to take it now, Sarah."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Administer it. My infection is progressing, and I cannot think clearly without a clear mind."
                  }
                ]
              }
            },
            {
              "step": 22,
              "action": "USE_CURE",
              "actor": "player",
              "parameters": {
                "item": "antidote_1",
                "target": "sarah"
              }
            }
          ]
        },
        {
          "quest_id": "Q1-3",
          "quest_title": "Securing the Future",
          "steps": [
