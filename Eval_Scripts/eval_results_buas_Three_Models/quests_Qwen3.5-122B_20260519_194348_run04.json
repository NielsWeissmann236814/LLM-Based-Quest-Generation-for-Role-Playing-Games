                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "George, the lab is locked and dark. We need power to help Sarah."
                  },
                  {
                    "speaker": "george",
                    "line": "Power is out because the main fuse blew. I can't fix it without a replacement. Do you have one?"
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I found a fuse in the lab, but I couldn't get in. Now I have it."
                  },
