            {
              "step": 2,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "player",
                    "line": "Mary, the situation is critical. We need to leave this island now."
                  },
                  {
                    "speaker": "mary",
                    "line": "I've been waiting for you. The boat's a wreck, but I can fix it if you bring the tools. I have the wood, but I lack the kit."
                  },
                  {
                    "speaker": "player",
                    "line": "I have the toolkit in my inventory. We can get this done quickly."
                  },
                  {
                    "speaker": "mary",
                    "line": "Good. Let's not waste time. The tide won't wait, and neither will the things in the water."
                  }
                ]
              }
            },
            {
              "step": 3,
              "action": "REPAIR",
              "actor": "player",
              "parameters": {
                "toolkit_item": "toolkit_1",
                "wood_item": "wood_1",
                "target": "boat",
                "place": "dock"
              }
            },
            {
              "step": 4,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "mary",
                    "line": "She's seaworthy. Finally. Get on board. We're leaving."
                  },
                  {
                    "speaker": "player",
                    "line": "It's time. The island has had enough."
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  }
