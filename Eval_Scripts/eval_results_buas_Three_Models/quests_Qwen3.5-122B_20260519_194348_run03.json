      "quest_type": "main",
      "required": true,
      "scale": "medium",
      "quests": [
        {
          "quest_id": "Q1_1",
          "quest_title": "The Storekeeper's Intel",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "safehouse",
                "to": "village"
              }
            },
            {
              "step": 2,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "store"
              }
            },
            {
              "step": 3,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "anne",
                "place": "store",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "The village is dying, Anne. I need to know if there's any way to stop it."
                  },
                  {
                    "speaker": "anne",
                    "line": "Dying is a slow process, but the end is coming faster than most admit. If you're looking for a miracle, it's not in my shelves."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah mentioned a cure. Is she still in the lab?"
                  },
                  {
                    "speaker": "anne",
                    "line": "Sarah is in the laboratory, yes. But that place is a tomb right now. No power, and the door is locked tighter than a banker's safe. You'll need the key from the graveyard and a fuse to get the lights on. Without those, she's just a prisoner in there."
                  }
                ]
              }
            }
          ]
        },
        {
          "quest_id": "Q1_2",
          "quest_title": "Key to the Dead",
          "steps": [
            {
              "step": 4,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "store",
                "to": "village"
              }
            },
            {
              "step": 5,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "graveyard"
              }
            },
            {
              "step": 6,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "lab_key_1",
                "place": "graveyard"
              }
            },
            {
              "step": 7,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "graveyard",
                "to": "village"
              }
            }
          ]
        },
        {
          "quest_id": "Q1_3",
          "quest_title": "Power to the People",
          "steps": [
            {
              "step": 8,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "powerstation"
              }
            },
            {
              "step": 9,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "george",
                "place": "powerstation",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "George, the lab is dark. I need to get power back to Sarah."
                  },
                  {
                    "speaker": "george",
                    "line": "The grid is dead. I can't fix it without a fuse. I've been scanning the perimeter, but the only one I know of was last seen in the lab. If you have it, I can install it."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I don't have the fuse yet, but I'm going to the lab to get it. Once I unlock the door, I'll bring it here."
                  },
                  {
                    "speaker": "george",
                    "line": "Make it quick. The longer the grid is down, the more we lose. I'll be here waiting."
                  }
                ]
              }
            }
          ]
        },
        {
          "quest_id": "Q1_4",
          "quest_title": "The Locked Door",
          "steps": [
            {
              "step": 10,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "powerstation",
                "to": "village"
              }
            },
            {
              "step": 11,
