  {
    "model": "Qwen3.5-122B",
    "run": 3,
    "chapter_id": "C2",
    "quest_data": {
      "chapter_id": "C2",
      "chapter_title": "The Puppeteer's Shadow",
      "quest_type": "main",
      "required": true,
      "scale": "large",
      "quests": [
        {
          "quest_id": "Q_C2_1",
          "quest_title": "The Doctor's Ledger",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 2,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "outpost1"
              }
            },
            {
              "step": 3,
              "action": "UNLOCK",
              "actor": "player",
              "parameters": {
                "key_item": "outpost_key_1",
                "target_place": "outpost1"
              }
            },
            {
              "step": 4,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "outpost2"
              }
            },
            {
              "step": 5,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost3"
              }
            },
            {
              "step": 6,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "the_doctor",
                "place": "outpost3",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "I found your notes, Doctor. You're not just studying the infection; you're engineering the chaos."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Engineering implies a lack of control. I am merely observing the variables. Viktor provides the pressure; I provide the data."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Viktor thinks he's in charge. He doesn't know you're the one pulling the strings."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Power is a crude metric. Influence is permanent. However, your presence is a disruption I had not calculated."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I'm here to stop it. Where is the evidence that links you to the outbreaks?"
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Evidence is in the details. Look in the crate marked 'Supplies' in the corner. If you survive reading it, perhaps you'll understand."
                  }
                ]
              }
            },
            {
              "step": 7,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "toolkit_1",
                "place": "outpost3"
              }
            }
          ]
        },
        {
          "quest_id": "Q_C2_2",
          "quest_title": "The Power of Truth",
          "steps": [
            {
              "step": 8,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost3",
                "to": "outpost2"
              }
            },
            {
              "step": 9,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost1"
              }
            },
            {
              "step": 10,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "village"
              }
            },
            {
              "step": 11,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "powerstation"
              }
            },
            {
              "step": 12,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "george",
                "place": "powerstation",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "George, the Doctor is manipulating the grid to hide his movements. I need to trace the power lines back to his lab."
                  },
                  {
                    "speaker": "george",
                    "line": "The grid is stable. Unless you have a reason to shut it down, leave it alone. I don't have time for theories."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "It's not a theory. He's using the power fluctuations to mask his supply runs. I need to turn the power off at the source to see the heat signatures."
                  },
                  {
                    "speaker": "george",
                    "line": "Shutting down the grid is a tactical error. It leaves the village blind. But if you have proof... show me."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I have the Doctor's ledger. It details the unauthorized power draws. If we cut the main line, we expose the hidden circuits."
                  },
                  {
                    "speaker": "george",
                    "line": "Very well. Do it. But if this causes a cascade failure, you're fixing it."
                  }
                ]
              }
            }
          ]
        },
        {
          "quest_id": "Q_C2_3",
          "quest_title": "The Hidden Lab",
          "steps": [
            {
              "step": 13,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "powerstation",
                "to": "village"
              }
            },
            {
              "step": 14,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "laboratory"
              }
            },
            {
              "step": 15,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, the power is down in the main grid. The Doctor's hidden lab is now visible on the thermal scan."
                  },
                  {
                    "speaker": "sarah",
                    "line": "I knew it. His energy signature was inconsistent with the stated output. We need to secure that location before he destroys the data."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I have the toolkit and the evidence. We need to get inside before he evacuates."
                  },
                  {
                    "speaker": "sarah",
                    "line": "The lab is locked. You'll need the key. I believe Viktor has it, or the Doctor keeps a spare in the cave."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I found the key in the cave earlier. It's in my inventory."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Then go. I will stay here and prepare the containment protocols. If he tries to flee, we need to be ready."
                  }
                ]
              }
            },
            {
              "step": 16,
              "action": "UNLOCK",
              "actor": "player",
              "parameters": {
                "key_item": "lab_key_1",
                "target_place": "laboratory"
              }
            }
          ]
        },
        {
          "quest_id": "Q_C2_4",
          "quest_title": "Confronting the Architect",
          "steps": [
            {
              "step": 17,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 18,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "outpost1"
              }
            },
            {
              "step": 19,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "outpost2"
              }
            },
            {
              "step": 20,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost3"
              }
            },
            {
              "step": 21,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "the_doctor",
                "place": "outpost3",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "The power is off, Doctor. Your hidden lab is exposed. It's over."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Exposed? A temporary setback. The data is already transmitted to the secure server. You have nothing."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "We have the ledger. We have the evidence of your crimes. Viktor will turn on you when he realizes he's been used."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Viktor is a tool. Tools can be replaced. My work cannot. But I will not let you destroy it."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Then we'll take you into custody. The village needs to know the truth."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Truth is subjective. I prefer results. If you insist on interfering, I will ensure your removal is... permanent."
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  },
  {
    "model": "Qwen3.5-122B",
