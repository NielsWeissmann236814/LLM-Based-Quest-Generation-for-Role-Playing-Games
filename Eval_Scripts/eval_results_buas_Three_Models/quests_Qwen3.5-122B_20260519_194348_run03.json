    "quest_data": {
      "chapter_id": "C3",
      "chapter_title": "The Final Departure",
      "quest_type": "main",
      "required": true,
      "scale": "large",
      "quests": [
        {
          "quest_id": "Q_C3_01",
          "quest_title": "The Boat's Last Hope",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost3",
                "to": "outpost2"
              }
            },
            {
              "step": 2,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "village"
              }
            },
            {
              "step": 3,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "dock"
              }
            },
            {
              "step": 4,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "MARY",
                    "line": "You're late. The tide's turning, and that boat isn't going to fix itself."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I have the toolkit. Tell me what else you need to get this thing seaworthy."
                  },
                  {
                    "speaker": "MARY",
                    "line": "Wood. A lot of it. The hull's split open. I've scoured the beach, but the rot's deep. You find wood, I'll handle the nails and the sealant."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "There's wood in the village. I can grab it and bring it back."
                  },
                  {
                    "speaker": "MARY",
                    "line": "Do it. And don't dawdle. If Viktor's men spot us, we're done. Once it's fixed, we leave. No arguments."
                  }
                ]
              }
            },
            {
              "step": 5,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "dock",
                "to": "village"
              }
            },
            {
              "step": 6,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "wood_1",
                "place": "village"
              }
            },
            {
              "step": 7,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "wood_2",
                "place": "village"
              }
            },
            {
              "step": 8,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "wood_3",
                "place": "village"
              }
            },
            {
              "step": 9,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "dock"
              }
            },
            {
              "step": 10,
              "action": "REPAIR",
              "actor": "player",
              "parameters": {
                "toolkit_item": "toolkit_1",
                "wood_item": "wood_1",
                "target": "boat",
                "place": "dock"
              }
            }
          ]
        },
        {
          "quest_id": "Q_C3_02",
          "quest_title": "Light in the Lab",
          "steps": [
            {
              "step": 11,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "dock",
                "to": "village"
              }
            },
            {
              "step": 12,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "outpost1"
              }
            },
            {
              "step": 13,
              "action": "UNLOCK",
              "actor": "player",
              "parameters": {
                "key_item": "outpost_key_1",
                "target_place": "outpost2"
              }
            },
            {
              "step": 14,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost3"
              }
            },
            {
              "step": 15,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost3",
                "to": "village"
              }
            },
            {
              "step": 16,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "cave"
              }
            },
            {
              "step": 17,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "outpost_key_1",
                "place": "cave"
              }
            },
            {
              "step": 18,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "cave",
                "to": "village"
              }
            },
            {
              "step": 19,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "laboratory"
              }
            },
            {
              "step": 20,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "SARAH",
                    "line": "You're here. I was analyzing the last batch of samples. The power is on, but without a viable sample, the machine is just a very expensive paperweight."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "The Doctor has the sample. Or he did. We need to get it to finish the cure."
                  },
                  {
                    "speaker": "SARAH",
                    "line": "He's hoarding it at the outpost. If we can retrieve it, I can synthesize the antidote immediately. But be warned, the Doctor won't give it up without a fight, or a very convincing argument."
                  },
                  {
                    "speaker": "PLAYER",
