              "parameters": {
                "key_item": "lab_key_1",
                "target_place": "laboratory"
              }
            },
            {
              "step": 13,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "fuse_1",
                "place": "laboratory"
              }
            },
            {
              "step": 14,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 15,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "powerstation"
              }
            },
            {
              "step": 16,
              "action": "TURN_POWER_ON",
              "actor": "player",
              "parameters": {
                "fuse_item": "fuse_1",
                "place": "powerstation",
                "target_place": "laboratory"
              }
            }
          ]
        },
        {
          "quest_id": "Q1_5",
          "quest_title": "The Cure Sample",
          "steps": [
            {
              "step": 17,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "powerstation",
                "to": "village"
              }
            },
            {
              "step": 18,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "hospital1"
              }
            },
            {
              "step": 19,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital1",
                "to": "hospital2"
              }
            },
            {
              "step": 20,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "cure_sample_1",
                "place": "hospital2"
              }
            },
            {
              "step": 21,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital2",
                "to": "hospital1"
              }
            },
            {
              "step": 22,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital1",
                "to": "village"
              }
            },
            {
              "step": 23,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "laboratory"
              }
            },
            {
              "step": 24,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, I have the fuse and the power is back on. I also found the sample."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Finally. I've been running simulations in the dark, waiting for the lights. With the power restored and the sample in hand, we can synthesize an antidote."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Can you make it now?"
                  },
                  {
                    "speaker": "sarah",
                    "line": "I can, but I'm infected. I can't operate the machine myself without risking the contamination of the process. You'll have to do it. Use the machine with the sample I've prepared for you."
                  }
                ]
              }
            },
            {
              "step": 25,
              "action": "SYNTHESIZE_CURE",
              "actor": "player",
              "parameters": {
                "place": "laboratory"
              }
            }
          ]
        },
        {
          "quest_id": "Q1_6",
          "quest_title": "A Dose of Hope",
          "steps": [
            {
              "step": 26,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "It's done. I have the antidote. Let me cure you, Sarah."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Thank you. I was losing my grip on the data. This should clear the infection and allow me to help you properly."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "We need to get this to the others who are sick."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Agreed. But first, I need to recover. Once I'm well, we can discuss the distribution strategy."
                  }
                ]
              }
            },
            {
              "step": 27,
              "action": "USE_CURE",
              "actor": "player",
              "parameters": {
                "item": "antidote_1",
                "target": "sarah"
              }
            }
          ]
        }
      ]
    }
