            },
            {
              "step": 18,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital1",
                "to": "village"
              }
            },
            {
              "step": 19,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "laboratory"
              }
            },
            {
              "step": 20,
              "action": "SYNTHESIZE_CURE",
              "actor": "player",
              "parameters": {
                "place": "laboratory"
