              "parameters": {
                "target": "marcus",
                "place": "hospital2",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Marcus, this place is exposed. We need to fortify it."
                  },
                  {
                    "speaker": "marcus",
                    "line": "I've been trying. Not enough materials."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I brought wood. Let's make this place secure."
                  },
                  {
                    "speaker": "marcus",
                    "line": "Good. Do it. I'll watch the door."
                  }
                ]
              }
            },
            {
