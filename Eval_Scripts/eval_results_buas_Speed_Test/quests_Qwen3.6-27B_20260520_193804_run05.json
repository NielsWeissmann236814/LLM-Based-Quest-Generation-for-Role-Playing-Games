            {
              "step": 37,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "the_doctor",
                "place": "outpost3",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Doctor, I need the toolkit. Mary is waiting at the dock."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Mary? The boatwoman? She is irrelevant to my work."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "If you don't give it to me, I'll shut down your power supply again."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "You would risk the stability of the outpost for a boat? Very well. Take it."
                  }
                ]
              }
            },
            {
              "step": 38,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "toolkit_1",
