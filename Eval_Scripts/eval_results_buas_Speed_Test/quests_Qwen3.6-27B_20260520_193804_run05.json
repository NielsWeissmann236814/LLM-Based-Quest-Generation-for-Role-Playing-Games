            {
              "step": 44,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Mary, I got the toolkit and some wood. Let's fix that boat."
                  },
                  {
                    "speaker": "mary",
                    "line": "About time. I'm not staying on this rock much longer."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Who wants to leave with you?"
                  },
                  {
