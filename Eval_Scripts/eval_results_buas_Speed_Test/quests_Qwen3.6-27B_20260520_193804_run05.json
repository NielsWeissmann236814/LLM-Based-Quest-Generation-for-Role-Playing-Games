                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah is infected. She needs the synthesizer."
                  },
                  {
                    "speaker": "george",
                    "line": "Hmph. Science over survival. Fine. Hand it over."
                  }
                ]
              }
            },
            {
              "step": 11,
              "action": "TURN_POWER_ON",
