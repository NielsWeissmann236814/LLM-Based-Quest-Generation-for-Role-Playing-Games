                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Marcus, I need the cure sample. It's for Sarah."
                  },
                  {
                    "speaker": "marcus",
                    "line": "Sarah? The scientist? She's been hoarding resources."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "She's dying, Marcus. If she dies, we all die. Give it to me."
                  },
                  {
                    "speaker": "marcus",
                    "line": "Fine. But if this is a trick, I won't forgive you."
                  }
                ]
              }
            },
            {
              "step": 16,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "cure_sample_1",
                "place": "hospital2"
              }
            },
            {
              "step": 17,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital2",
