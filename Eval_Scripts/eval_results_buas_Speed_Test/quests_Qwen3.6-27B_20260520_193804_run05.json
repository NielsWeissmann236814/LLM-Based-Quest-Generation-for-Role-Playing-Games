            },
            {
              "step": 21,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "I synthesized the antidote. Hold still."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Thank you... I was losing hope."
                  }
                ]
              }
            },
            {
              "step": 22,
