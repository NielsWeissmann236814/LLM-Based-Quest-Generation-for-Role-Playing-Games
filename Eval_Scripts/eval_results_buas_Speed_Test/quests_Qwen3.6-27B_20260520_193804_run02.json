      "quests": [
        {
          "quest_id": "Q2_1",
          "quest_title": "Infiltrating the Outpost",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
