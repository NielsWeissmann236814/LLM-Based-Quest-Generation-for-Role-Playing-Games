              "step": 13,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "hospital1"
              }
            },
            {
              "step": 14,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital1",
                "to": "hospital2"
              }
            },
            {
              "step": 15,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "marcus",
                "place": "hospital2",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Marcus, I need the cure sample. Sarah is ready to synthesize."
                  },
                  {
                    "speaker": "marcus",
                    "line": "It's on the table. Take it. We can't hold this position forever."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "You're coming with me?"
                  },
                  {
                    "speaker": "marcus",
                    "line": "Someone has to keep the zombies off your back while you work. Move fast."
                  }
                ]
              }
            },
            {
              "step": 16,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "cure_sample_1",
                "place": "hospital2"
              }
            },
            {
              "step": 17,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital2",
                "to": "hospital1"
              }
            },
            {
              "step": 18,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital1",
                "to": "village"
              }
            },
            {
              "step": 19,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "laboratory"
              }
            },
            {
              "step": 20,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "I have the sample. The power is on."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Place it in the synthesizer. I'll monitor the reaction."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Do it now."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Initiating synthesis. Pray the calculations are correct."
                  }
                ]
              }
            },
            {
              "step": 21,
              "action": "SYNTHESIZE_CURE",
              "actor": "player",
              "parameters": {
                "place": "laboratory"
              }
            },
            {
              "step": 22,
              "action": "USE_CURE",
              "actor": "player",
              "parameters": {
                "item": "antidote_1",
                "target": "sarah"
              }
            },
            {
              "step": 23,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah? How do you feel?"
                  },
                  {
                    "speaker": "sarah",
                    "line": "Clear. The fever is gone. I can think again."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "We have a cure. What's next?"
                  },
                  {
                    "speaker": "sarah",
                    "line": "We need to secure the village. And we need to stop Viktor before he burns it all down."
                  }
                ]
              }
            }
          ]
