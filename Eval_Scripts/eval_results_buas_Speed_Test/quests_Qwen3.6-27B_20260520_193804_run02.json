              "step": 13,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "village"
              }
            },
            {
              "step": 14,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "wood_1",
                "place": "village"
              }
            },
            {
              "step": 15,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "dock"
              }
            },
            {
              "step": 16,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "mary",
                    "line": "You're late. The tide doesn't wait for anyone."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I got the tools you needed. And some wood."
                  },
                  {
                    "speaker": "mary",
                    "line": "Good. Hand them over. If this boat floats, we leave. If it sinks, we die. Simple calculus."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "It'll float. I promise."
                  },
                  {
                    "speaker": "mary",
                    "line": "Promises are cheap. Steel and wood are not. Get to work."
                  }
                ]
              }
            },
            {
              "step": 17,
              "action": "REPAIR",
              "actor": "player",
              "parameters": {
                "toolkit_item": "toolkit_1",
                "wood_item": "wood_1",
                "target": "boat",
                "place": "dock"
              }
            }
          ]
        },
        {
          "quest_id": "Q2_3",
          "quest_title": "Fortifying the Line",
          "steps": [
            {
              "step": 18,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
