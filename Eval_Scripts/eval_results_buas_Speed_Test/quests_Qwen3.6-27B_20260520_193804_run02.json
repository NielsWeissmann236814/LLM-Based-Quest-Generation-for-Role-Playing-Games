                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah? Can you hear me? I got the lab open."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Yes... I see you. The door is open. But the machines are dark."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I know. I found a fuse inside. I just need to get power to the grid."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Then do it quickly. The infection... it moves faster than I can think."
                  }
                ]
              }
            },
            {
              "step": 7,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "fuse_1",
                "place": "laboratory"
              }
            },
            {
              "step": 8,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 9,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "powerstation"
              }
            },
            {
              "step": 10,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "george",
                "place": "powerstation",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "George, I have the fuse for the lab. Sarah needs power to work on a cure."
                  },
                  {
                    "speaker": "george",
                    "line": "The lab's grid is isolated. Hand it over. I'll route the current."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Take it. Is it safe?"
                  },
                  {
                    "speaker": "george",
                    "line": "It will be. Just don't ask me to fix the generator again."
                  }
                ]
              }
            },
            {
              "step": 11,
              "action": "TURN_POWER_ON",
              "actor": "player",
              "parameters": {
                "fuse_item": "fuse_1",
                "place": "powerstation",
                "target_place": "laboratory"
              }
            }
          ]
        },
        {
          "quest_id": "Q2_C1_CureSynthesis",
          "quest_title": "The Synthesis",
          "steps": [
            {
              "step": 12,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "powerstation",
                "to": "village"
