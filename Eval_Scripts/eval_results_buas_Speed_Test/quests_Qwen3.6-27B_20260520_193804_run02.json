            },
            {
              "step": 21,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital1",
                "to": "hospital2"
              }
            },
            {
              "step": 22,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "marcus",
                "place": "hospital2",
                "dialogue_content": [
                  {
                    "speaker": "marcus",
                    "line": "Hold position. The dead are massing near the perimeter."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I brought wood. We can reinforce the walls."
                  },
                  {
                    "speaker": "marcus",
                    "line": "Do it. A fortified position buys time. Time buys survival."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Consider it done."
                  },
                  {
                    "speaker": "marcus",
                    "line": "Good. Stay sharp. Viktor's men won't be far behind."
                  }
                ]
              }
            },
            {
              "step": 23,
              "action": "FORTIFY",
              "actor": "player",
              "parameters": {
                "wood_item": "wood_2",
