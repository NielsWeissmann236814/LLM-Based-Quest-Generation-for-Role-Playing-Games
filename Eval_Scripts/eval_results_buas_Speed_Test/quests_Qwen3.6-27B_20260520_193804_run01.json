    "quest_data": {
      "chapter_id": "C2",
      "chapter_title": "The Puppeteer's Strings",
      "quest_type": "main",
      "required": true,
      "scale": "large",
      "quests": [
        {
          "quest_id": "Q2_1",
          "quest_title": "Gathering Intel",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 2,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "anne",
                "place": "store",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Anne, I need to know who's really running this island. The Doctor? Viktor?"
                  },
                  {
                    "speaker": "anne",
                    "line": "Viktor holds the guns, but The Doctor holds the secrets. I've seen crates moving into the Outpost that aren't marked for supplies. They're labeled 'Research Samples'."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Can I get inside the Outpost to see what they're hiding?"
                  },
                  {
                    "speaker": "anne",
                    "line": "The main gate is locked. But there's a key in the Cave, near the old ruins. Be careful. Viktor's men patrol the roads, but the Cave is quiet."
                  }
                ]
              }
            },
            {
              "step": 3,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "cave"
              }
            },
            {
              "step": 4,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "outpost_key_1",
                "place": "cave"
              }
            }
          ]
        },
        {
          "quest_id": "Q2_2",
          "quest_title": "Into the Lion's Den",
          "steps": [
            {
              "step": 5,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "cave",
                "to": "village"
              }
            },
            {
              "step": 6,
              "action": "UNLOCK",
              "actor": "player",
              "parameters": {
                "key_item": "outpost_key_1",
                "target_place": "outpost1"
              }
            },
            {
              "step": 7,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "outpost2"
              }
            },
            {
              "step": 8,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "viktor",
                "place": "outpost2",
                "dialogue_content": [
                  {
                    "speaker": "viktor",
                    "line": "You have a knack for finding trouble, or perhaps trouble finds you. State your business."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I'm here to see what you're doing with the island's resources. And why The Doctor is so interested in our survival."
                  },
                  {
                    "speaker": "viktor",
                    "line": "The Doctor ensures order through science. I ensure order through strength. Do not mistake my protection for tyranny. Leave before I decide you are a variable I need to eliminate."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Your 'order' is built on fear. I'm going deeper."
                  },
                  {
                    "speaker": "viktor",
                    "line": "Then you will find only what you deserve."
                  }
                ]
              }
            },
            {
              "step": 9,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost3"
              }
            },
            {
              "step": 10,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "the_doctor",
                "place": "outpost3",
                "dialogue_content": [
                  {
                    "speaker": "the_doctor",
                    "line": "Ah, the curious subject. You are in my workspace now. Do try not to contaminate the samples."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "You're using people as test subjects. This isn't research, it's murder."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Murder implies intent to kill without purpose. I am accelerating evolution. The outbreak is merely a phase transition. Viktor provides the containment; I provide the future."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Your future ends today. I'm taking everything you've built."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "You cannot stop progress. But you may delay it. Take the toolkit if you wish to play mechanic. It will not save you."
                  }
                ]
              }
            },
            {
              "step": 11,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "toolkit_1",
                "place": "outpost3"
              }
            }
          ]
        },
        {
          "quest_id": "Q2_3",
          "quest_title": "The Escape Route",
          "steps": [
            {
              "step": 12,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
