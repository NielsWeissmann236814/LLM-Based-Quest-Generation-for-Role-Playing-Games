              "step": 15,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "wood_1",
                "place": "village"
              }
            },
            {
              "step": 16,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "dock"
              }
            },
            {
              "step": 17,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Mary, I found a toolkit in the Outpost. I can fix your boat."
                  },
                  {
                    "speaker": "mary",
                    "line": "About time. I've been waiting for someone with skills, not just talk. Hand it over and let's get this hull sealed."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Once it's fixed, we can leave this island. No more Viktor, no more Doctor."
                  },
                  {
                    "speaker": "mary",
                    "line": "That's the plan. I don't like relying on others, but the sea is the only place I feel free. Let's get to work."
                  }
                ]
              }
            },
            {
              "step": 18,
              "action": "REPAIR",
              "actor": "player",
              "parameters": {
                "toolkit_item": "toolkit_1",
                "wood_item": "wood_1",
                "target": "boat",
                "place": "dock"
              }
            }
          ]
        }
      ]
    }
