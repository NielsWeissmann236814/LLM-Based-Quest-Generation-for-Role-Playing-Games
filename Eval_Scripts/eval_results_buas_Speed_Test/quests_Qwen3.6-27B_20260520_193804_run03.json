              }
            }
          ]
        },
        {
          "quest_id": "Q2_C1",
          "quest_title": "Powering Up",
          "steps": [
            {
              "step": 11,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "powerstation"
              }
            },
            {
              "step": 12,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "george",
                "place": "powerstation",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "George, I found a fuse in the lab. Can you get the power on?"
                  },
                  {
                    "speaker": "george",
                    "line": "I can't leave my post. But you can install it. It's a simple swap. Just be careful with the contacts."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Will it work for the lab?"
                  },
                  {
                    "speaker": "george",
                    "line": "If the wiring holds, yes. It's all on the same grid."
                  }
                ]
              }
            },
            {
              "step": 13,
              "action": "TURN_POWER_ON",
              "actor": "player",
              "parameters": {
                "fuse_item": "fuse_1",
                "place": "powerstation",
                "target_place": "laboratory"
              }
            }
          ]
        },
        {
          "quest_id": "Q3_C1",
          "quest_title": "The Sample",
          "steps": [
            {
              "step": 14,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "powerstation",
                "to": "village"
              }
            },
            {
              "step": 15,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "hospital1"
              }
            },
            {
              "step": 16,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital1",
                "to": "hospital2"
              }
            },
            {
              "step": 17,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "marcus",
                "place": "hospital2",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Marcus, I need that cure sample. Sarah is waiting."
                  },
                  {
                    "speaker": "marcus",
                    "line": "It's not mine to give. But if it saves people, take it. Don't waste it."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I won't."
                  }
                ]
              }
            },
            {
              "step": 18,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "cure_sample_1",
                "place": "hospital2"
              }
            },
            {
              "step": 19,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital2",
                "to": "hospital1"
              }
            },
            {
              "step": 20,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "hospital1",
                "to": "village"
              }
            },
            {
              "step": 21,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "laboratory"
              }
            },
            {
              "step": 22,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, I brought the sample and the power is back on."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Thank you. My hands are shaking, but my mind is clear. I need to synthesize the antidote immediately."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I'll handle the machine. You rest."
                  },
                  {
                    "speaker": "sarah",
                    "line": "No, I must oversee it. But you can run the synthesis. I'll guide you."
                  }
                ]
              }
            },
            {
              "step": 23,
              "action": "SYNTHESIZE_CURE",
              "actor": "player",
              "parameters": {
                "place": "laboratory"
              }
            }
          ]
        },
        {
          "quest_id": "Q4_C1",
          "quest_title": "A New Hope",
          "steps": [
            {
              "step": 24,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
