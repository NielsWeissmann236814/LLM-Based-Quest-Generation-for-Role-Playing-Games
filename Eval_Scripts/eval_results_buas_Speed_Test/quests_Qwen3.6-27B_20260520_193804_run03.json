          "quest_id": "Q3_01",
          "quest_title": "Departure",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "dock",
                "to": "dock"
              }
            },
            {
              "step": 2,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Mary, the boat is fixed. We can leave."
                  },
                  {
                    "speaker": "mary",
                    "line": "I checked the engine myself. She's ready. The tide is turning in an hour."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Then we don't have time to waste. Is there room for anyone else?"
                  },
                  {
                    "speaker": "mary",
                    "line": "Room for two, maybe three if they're quiet. But this is my boat. I'm the one steering us off this rock. You're coming with me."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Agreed. Let's go."
                  }
                ]
              }
            },
            {
              "step": 3,
              "action": "USE_CURE",
              "actor": "player",
              "parameters": {
                "item": "antidote_1",
                "target": "mary"
              }
            }
          ]
        }
