  {
    "model": "Qwen3.6-27B",
    "run": 3,
    "chapter_id": "C2",
    "quest_data": {
      "chapter_id": "C2",
      "chapter_title": "Shadows of Control",
      "quest_type": "main",
      "required": true,
      "scale": "large",
      "quests": [
        {
          "quest_id": "Q2_01",
          "quest_title": "The Doctor's Ledger",
          "steps": [
            {
              "step": 1,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 2,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "sarah",
                "place": "laboratory",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Sarah, I'm heading out to the Outpost. I need to know what I'm walking into."
                  },
                  {
                    "speaker": "sarah",
                    "line": "Be careful. Viktor is consolidating power, but The Doctor... he's the architect. He views the outbreak as data."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Do you have proof? Something concrete?"
                  },
                  {
                    "speaker": "sarah",
                    "line": "I have theories. The Doctor has records. If you find his research logs, you'll see the timeline. He knew this was coming."
                  }
                ]
              }
            },
            {
              "step": 3,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "laboratory"
              }
            },
            {
              "step": 4,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "laboratory",
                "to": "village"
              }
            },
            {
              "step": 5,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "anne",
                "place": "store",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Anne, I'm going to confront Viktor. I need the outpost key."
                  },
                  {
                    "speaker": "anne",
                    "line": "I can't give you that. Viktor has men watching. But I heard a scout mentioned a cache in the cave near the old quarry."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "The cave? Is it safe?"
                  },
                  {
                    "speaker": "anne",
                    "line": "Safer than walking into Viktor's line of sight with empty hands. Check the cave. If the key is there, take it. But hurry."
                  }
                ]
              }
            },
            {
              "step": 6,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "cave"
              }
            },
            {
              "step": 7,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "outpost_key_1",
                "place": "cave"
              }
            },
            {
              "step": 8,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "cave",
                "to": "village"
              }
            },
            {
              "step": 9,
              "action": "UNLOCK",
              "actor": "player",
              "parameters": {
                "key_item": "outpost_key_1",
                "target_place": "outpost1"
              }
            },
            {
              "step": 10,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "outpost2"
              }
            },
            {
              "step": 11,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "viktor",
                "place": "outpost2",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Viktor. I know you're pulling the strings. But The Doctor is the one who started this."
                  },
                  {
                    "speaker": "viktor",
                    "line": "You speak of strings as if they are chains. I provide order. The Doctor provides... results. Do not confuse the two."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "Your order is built on lies. I'm going to his lab."
                  },
                  {
                    "speaker": "viktor",
                    "line": "Go ahead. See what you find. But remember, knowledge without power is just a burden. And I control the power here."
                  }
                ]
              }
            },
            {
              "step": 12,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost3"
              }
            },
            {
              "step": 13,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "the_doctor",
                "place": "outpost3",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "The Doctor. Sarah says you knew about the outbreak before it happened."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Sarah is a brilliant mind, but she lacks the stomach for the truth. I did not cause it. I observed it. And I prepared."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "You used people. You used this island as a test bed."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "I used resources. People are merely variables in a larger equation. If you want to stop the spread, you need the cure. If you want to stop me, you need more than moral outrage."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I'm taking your research. The world needs to know."
                  },
                  {
                    "speaker": "the_doctor",
                    "line": "Take it. It will only prove that chaos reigns when competence is removed. I have already secured copies elsewhere."
                  }
                ]
              }
            },
            {
              "step": 14,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "toolkit_1",
                "place": "outpost3"
              }
            }
          ]
        },
        {
          "quest_id": "Q2_02",
          "quest_title": "The Weight of Truth",
          "steps": [
            {
              "step": 15,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost3",
                "to": "outpost2"
              }
            },
            {
              "step": 16,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost2",
                "to": "outpost1"
              }
            },
            {
              "step": 17,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "outpost1",
                "to": "village"
              }
            },
            {
              "step": 18,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "anne",
                "place": "store",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "I spoke to Viktor and The Doctor. The Doctor admits he engineered the conditions for the outbreak."
                  },
                  {
                    "speaker": "anne",
                    "line": "I suspected as much. The shipments, the isolation... it was too clean. What did Viktor say?"
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "He claims he's maintaining order. But he's protecting The Doctor's work."
                  },
                  {
                    "speaker": "anne",
                    "line": "Then we have a choice. We can expose them, or we can use their resources. The boat is still broken. Mary needs help."
                  }
                ]
              }
            },
            {
              "step": 19,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "dock"
              }
            },
            {
              "step": 20,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "Mary, I have the toolkit from the Outpost. I can fix your boat."
                  },
                  {
                    "speaker": "mary",
                    "line": "You do? Good. I've been waiting for someone with the skills to back up the talk. I have wood, but I need your hands."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I'll need to grab some wood from the village first. I have the toolkit now."
                  },
                  {
                    "speaker": "mary",
                    "line": "Do it. Once this boat is fixed, we can leave this madness behind. Or we can take it further out. Your call."
                  }
                ]
              }
            },
            {
              "step": 21,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "dock",
                "to": "village"
              }
            },
            {
              "step": 22,
              "action": "PICKUP",
              "actor": "player",
              "parameters": {
                "item": "wood_1",
                "place": "village"
              }
            },
            {
              "step": 23,
              "action": "MOVE",
              "actor": "player",
              "parameters": {
                "from": "village",
                "to": "dock"
              }
            },
            {
              "step": 24,
              "action": "REPAIR",
              "actor": "player",
              "parameters": {
                "toolkit_item": "toolkit_1",
                "wood_item": "wood_1",
                "target": "boat",
                "place": "dock"
              }
            },
            {
              "step": 25,
              "action": "TALK",
              "actor": "player",
              "parameters": {
                "target": "mary",
                "place": "dock",
                "dialogue_content": [
                  {
                    "speaker": "PLAYER",
                    "line": "The boat is fixed. You're ready to go."
                  },
                  {
                    "speaker": "mary",
                    "line": "She's humming. Good work. I won't forget this. If you ever need a ride off this rock, you know where to find me."
                  },
                  {
                    "speaker": "PLAYER",
                    "line": "I might just take you up on that. For now, I have some loose ends to tie up."
                  },
                  {
                    "speaker": "mary",
                    "line": "Don't take too long. The tide waits for no one."
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  },
