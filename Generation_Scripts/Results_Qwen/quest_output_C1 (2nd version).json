          "parameters": {
            "dialogue_content": [
              {
                "speaker": "PLAYER",
                "line": "Sarah, I have the cure sample and the power's back on."
              },
              {
                "speaker": "sarah",
                "line": "Good. I've been monitoring the synthesis parameters. With power restored, we can begin."
              },
              {
                "speaker": "PLAYER",
                "line": "You're infected. We need to cure you first."
              },
              {
                "speaker": "sarah",
                "line": "Then synthesize the antidote. I'll guide you through the process. Use the machine."
              }
