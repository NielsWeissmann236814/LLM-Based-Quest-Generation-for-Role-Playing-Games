          "actor": "player",
          "target": "george",
          "place": "powerstation",
          "parameters": {
            "dialogue_content": [
              {
                "speaker": "PLAYER",
                "line": "George, I have a fuse. Can we restore power to the laboratory?"
              },
              {
                "speaker": "george",
                "line": "That's the lab fuse. Sarah's been dead set on getting that place running."
              },
              {
                "speaker": "PLAYER",
                "line": "She's infected. We need to get her a cure."
              },
              {
                "speaker": "george",
                "line": "Then let's get the power on. I'll stay here - you install it."
              }
            ]
          }
        },
        {
          "step": 14,
          "action": "TURN_POWER_ON",
          "actor": "player",
          "parameters": {
            "fuse_item": "fuse_1",
            "place": "powerstation",
            "target_place": "laboratory"
          }
        }
      ]
