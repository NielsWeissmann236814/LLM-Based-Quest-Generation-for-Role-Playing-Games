  "quests": [
    {
      "quest_id": "Q1-1",
      "quest_title": "Gather Information",
      "steps": [
        {
          "step": 1,
          "action": "MOVE",
          "actor": "player",
          "parameters": {
            "from": "safehouse",
            "to": "village"
          }
        },
        {
          "step": 2,
          "action": "MOVE",
          "actor": "player",
          "parameters": {
            "from": "village",
            "to": "store"
          }
        },
        {
          "step": 3,
          "action": "TALK",
          "actor": "player",
          "target": "anne",
          "place": "store",
          "parameters": {
            "dialogue_content": [
              {
                "speaker": "PLAYER",
                "line": "Anne, I need to understand what's happening to this village."
              },
              {
                "speaker": "anne",
                "line": "People are getting sick. Some turn, some die. Sarah was working on something in her lab before she went down."
              },
              {
                "speaker": "PLAYER",
                "line": "Sarah? She's at the laboratory?"
              },
              {
                "speaker": "anne",
                "line": "Was. She's infected now. The lab's locked tight though - you'll need the key from the graveyard."
              },
              {
                "speaker": "PLAYER",
                "line": "And the power? Can we get it working?"
              },
              {
                "speaker": "anne",
                "line": "George's at the powerstation. But Sarah mentioned a fuse... somewhere inside that lab. If you can get in, maybe there's a way."
              }
            ]
          }
        }
      ]
    },
    {
      "quest_id": "Q1-2",
