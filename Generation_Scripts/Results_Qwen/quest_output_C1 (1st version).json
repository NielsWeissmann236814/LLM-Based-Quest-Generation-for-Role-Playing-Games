          "action": "TALK",
          "actor": "player",
          "parameters": {
            "target": "george",
            "place": "powerstation",
            "dialogue_content": [
              {
                "speaker": "PLAYER",
                "line": "George, I need to restore power to the laboratory."
              },
              {
                "speaker": "george",
                "line": "The grid's been down for weeks. You have a fuse?"
              },
              {
                "speaker": "PLAYER",
                "line": "Yes. Will this work?"
              },
              {
                "speaker": "george",
                "line": "Should. Install it at the station and I'll route power to the lab. Keep the system stable."
              }
