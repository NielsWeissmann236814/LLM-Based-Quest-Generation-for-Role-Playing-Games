          "action": "TALK",
          "actor": "player",
          "parameters": {
            "target": "anne",
            "place": "store",
            "dialogue_content": [
              {
                "speaker": "PLAYER",
                "line": "Anne, what's happening to the village?"
              },
              {
                "speaker": "anne",
                "line": "People are falling sick. Sarah's been infected at the laboratory. It's spreading faster than anyone expected."
              },
              {
                "speaker": "PLAYER",
                "line": "Is there a cure?"
              },
              {
                "speaker": "anne",
                "line": "There might be. Sarah was working on something before she got sick. The lab has the equipment, but it's locked and has no power."
              },
              {
                "speaker": "PLAYER",
                "line": "Where do I find the key?"
              },
              {
                "speaker": "anne",
                "line": "The lab key is in the graveyard. Old burial site, north of the village. I wouldn't go there without being prepared."
              }
            ]
          }
        }
      ]
    },
    {
