            "to": "store"
          }
        },
        {
          "step": 3,
          "action": "TALK",
          "actor": "player",
          "parameters": {
            "target": "anne",
            "place": "store",
            "dialogue_content": [
              {
                "speaker": "PLAYER",
                "line": "Anne, I need to know what's happening. People are getting sick."
              },
              {
                "speaker": "anne",
                "line": "You've noticed then. Yes, the village is dying. I've been tracking who falls ill - it's spreading faster than we'd like."
              },
              {
                "speaker": "PLAYER",
                "line": "Is there anything we can do about it?"
              },
              {
                "speaker": "anne",
                "line": "Sarah's been working on something at the laboratory. She's infected now, but she left notes about a cure sample somewhere in the hospital."
              },
              {
                "speaker": "PLAYER",
                "line": "The laboratory? I can't get in - it's locked."
              },
              {
                "speaker": "anne",
                "line": "The key's in the graveyard. Sarah told me about it before she got too sick. Be careful out there, traveler."
              }
            ]
          }
        }
      ]
    },
    {
