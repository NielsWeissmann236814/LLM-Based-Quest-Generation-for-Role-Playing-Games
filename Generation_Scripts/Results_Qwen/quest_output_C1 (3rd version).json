    {
      "quest_id": "Q1_1",
      "quest_title": "Rumors in the Store",
      "steps": [
        {
          "step": 1,
          "action": "MOVE",
          "actor": "player",
          "parameters": {
            "from": "safehouse",
            "to": "village"
